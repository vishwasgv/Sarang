{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@shared/*": ["src/renderer/src/shared/*"],
      "@modules/*": ["src/renderer/src/modules/*"],
      "@app/*": ["src/renderer/src/app/*"],
      "@assets/*": ["src/renderer/src/assets/*"]
    }
  },
  "include": ["src/renderer/src/**/*", "src/main/ipc/channels.ts"]
}
