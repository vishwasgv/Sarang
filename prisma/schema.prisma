model TimeEntry {
  id          String   @id @default(cuid())
  employeeId  String?
  caseId      String? // For LAWYER; null = freestanding (CA, Arch etc.)
  projectId   String? // For ARCHITECT|CIVIL_ENGINEER|CONSULTANT|AGENCY
  // Phase 58 §1 (2026-07-17) — lets a logged hour count against a specific
  // HOURLY_BUCKET retainer's monthly hour allowance (see
  // retainer.service.ts's getRetainerHoursUsage, which sums TimeEntry.hours
  // by retainerId+period rather than mutating a stored running counter —
  // avoids the whole "did the monthly reset job run" class of bug).
  // Independent of caseId/projectId — a retainer-billed hour may or may not
  // also be tagged to a project.
  retainerId  String?
  date        DateTime
  description String
  hours       Decimal
  ratePerHour Decimal  @default(0)
  amount      Decimal  @default(0) // hours × ratePerHour, computed at service layer
  isBilled    Boolean  @default(false)
  invoiceId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee Employee?          @relation(fields: [employeeId], references: [id], onDelete: SetNull)
