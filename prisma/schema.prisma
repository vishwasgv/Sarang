  project  ServiceProject?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  retainer RetainerAgreement? @relation(fields: [retainerId], references: [id], onDelete: SetNull)

  @@index([employeeId])
  @@index([caseId])
  @@index([projectId])
  @@index([retainerId])
  @@index([date])
  @@index([isBilled])
}

// ─── Phase 29 — CA + CS ───────────────────────────────────────────────────────

model ComplianceEvent {
  id            String   @id @default(cuid())
  title         String // "GSTR-3B Filing"
  category      String // INCOME_TAX|GST|TDS|ROC|MCA|AUDIT|OTHER
  frequency     String   @default("ANNUAL") // ANNUAL|QUARTERLY|MONTHLY|ONE_TIME
  applicableTo  String   @default("ALL") // ALL|COMPANY|INDIVIDUAL|LLP|FIRM
  description   String? // due date hint text
  // Structured due date, additive — nullable so AGM-relative ROC/MCA events
  // (whose real due date depends on each client's own AGM date, not tracked
  // anywhere in this schema) can stay unset and are simply excluded from
  // auto-generation rather than guessed at. dueMonth null + dueDay set means
  // "this day of every month" (GSTR-1/GSTR-3B); both set means a single fixed
  // calendar date recurring once a year (covers ANNUAL and the pre-split
  // per-quarter QUARTERLY rows alike).
  dueMonth      Int? // 1-12, null = monthly recurrence
  dueDay        Int? // 1-31, null = not auto-computable (AGM-relative)
  // Phase 58 §2 — set ONLY for the 3 events with a precise, non-negotiable
  // statutory offset from a company's AGM date (MGT-7:60, AOC-4:30, ADT-1:15
  // days). The AGM event itself deliberately stays un-auto-computable — its
  // real due date depends on FY-end + board scheduling, not a fixed offset
  // from the PREVIOUS AGM, so guessing it would risk asserting a wrong
  // statutory deadline (this codebase's "never guess a derived fact"
  // discipline, same reasoning as `dueDay` staying null above).
  agmOffsetDays Int?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks ComplianceTask[]

  @@index([category])
  @@index([isActive])
}

model ComplianceTask {
  id                String    @id @default(cuid())
  complianceEventId String?
  clientId          String
  staffId           String?
  title             String
  category          String // INCOME_TAX|GST|TDS|ROC|MCA|AUDIT|OTHER
  dueDate           DateTime
  status            String    @default("PENDING") // PENDING|IN_PROGRESS|FILED|DONE|OVERDUE
  priority          String    @default("NORMAL") // LOW|NORMAL|HIGH|URGENT
  notes             String?
  filedOn           DateTime?
  acknowledgmentNo  String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  event  ComplianceEvent? @relation(fields: [complianceEventId], references: [id], onDelete: SetNull)
  client Customer         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff  Employee?        @relation("TaskStaff", fields: [staffId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([dueDate])
  @@index([status])
  @@index([staffId])
  @@index([complianceEventId])
}

// Phase 58 §2 — CA Firm client-wise document checklist (PAN/Aadhaar/bank
// statements etc. collected vs. pending). Deliberately standalone, NOT
// linked to the generic Document/DocumentPanel attachment system — this is
// a collection-status tracker (has the client SUBMITTED it yet), not a file
// store; a CA can separately attach the actual scanned file elsewhere via
// the same DocumentPanel already wired onto ComplianceTask/Engagement.
model ClientDocumentChecklistItem {
  id            String    @id @default(cuid())
  clientId      String
  documentType  String // PAN|AADHAAR|BANK_STATEMENT|GST_CERTIFICATE|OTHER
  label         String? // custom label when documentType = OTHER
  status        String    @default("PENDING") // PENDING|COLLECTED
  collectedDate DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client Customer @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
}

model Engagement {
  id                 String    @id @default(cuid())
  clientId           String
  staffId            String?
  title              String // "GST Filing & Advisory Retainer"
  engagementType     String    @default("RETAINER") // RETAINER|ONE_TIME|AUDIT|ADVISORY|TAX
  status             String    @default("ACTIVE") // ACTIVE|COMPLETED|PAUSED|TERMINATED
  startDate          DateTime?
  endDate            DateTime?
  feeType            String    @default("FIXED") // FIXED|HOURLY|RETAINER_MONTHLY
  feeAmount          Decimal?
  billingDay         Int? // day-of-month for retainer auto-invoice
  invoiceId          String? // reference to the MOST RECENT generated invoice (informational only — not used for re-invoicing gating, see lastInvoicedPeriod)
  lastInvoicedPeriod String? // "YYYY-MM" of the last period actually invoiced — the real re-invoicing claim key, same pattern as RetainerAgreement; invoiceId alone used to permanently block re-invoicing after month 1
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client Customer  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff  Employee? @relation("EngagementStaff", fields: [staffId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status])
  @@index([staffId])
}

model ROCFiling {
  id            String    @id @default(cuid())
  clientId      String
  staffId       String?
  formType      String // MGT-7|AOC-4|DIR-12|INC-22|PAS-3|ADT-1|MBP-1|OTHER
  financialYear String? // "2025-26"
  purpose       String?
  dueDate       DateTime?
  filedOn       DateTime?
  srn           String? // MCA Service Request Number
  status        String    @default("PENDING") // PENDING|IN_PROGRESS|FILED|ACKNOWLEDGED|DEFECTIVE
  govtFee       Decimal?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  client Customer  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff  Employee? @relation("ROCFilingStaff", fields: [staffId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([dueDate])
  @@index([status])
  @@index([staffId])
}

model BoardMeeting {
  id          String   @id @default(cuid())
  clientId    String
  meetingType String   @default("BOARD") // BOARD|AGM|EGM|AUDIT_COMMITTEE|NRC
  meetingDate DateTime
  meetingTime String?
  venue       String?
  agenda      String?
  quorumMet   Boolean  @default(false)
  minutesDone Boolean  @default(false) // quick status flag — kept alongside minutesText below, not replaced by it
  minutesText String? // Phase 54F — the actual minutes document text; minutesDone was previously the only record of a meeting's minutes, a checkbox with no content behind it
  noticesSent Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Customer          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  resolutions BoardResolution[] // Phase 54F — individual resolutions passed at this meeting

  @@index([clientId])
  @@index([meetingDate])
}

// Phase 54F — a real resolution register. Previously nothing recorded WHICH
// resolutions were passed at a board meeting, only that minutes existed
// (as a boolean). Numbered resolutions with their actual text are what a
// company secretary files/references, not a yes/no flag.
model BoardResolution {
  id                String   @id @default(cuid())
  boardMeetingId    String
  resolutionNumber  String // e.g. "1", "2024-03" — firm's own numbering convention, free text
  resolutionType    String   @default("ORDINARY") // ORDINARY|SPECIAL
  resolutionText    String
  passedUnanimously Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  boardMeeting BoardMeeting @relation(fields: [boardMeetingId], references: [id], onDelete: Cascade)

  @@index([boardMeetingId])
}

// ─── Phase 30 — Architect, Civil, Consultant, Agency ─────────────────────────

model Lead {
  id                String   @id @default(cuid())
  fullName          String
  email             String?
  phone             String?
  companyName       String?
  source            String   @default("REFERRAL") // REFERRAL|WEBSITE|WALK_IN|SOCIAL|COLD_CALL|OTHER
  status            String   @default("OPEN") // OPEN|CONTACTED|PROPOSAL|WON|LOST
  estimatedValue    Decimal?
  assignedToId      String?
  convertedClientId String? // set when WON and linked to a Customer
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assignedTo Employee? @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedToId])
}

model ServiceProject {
  id                 String    @id @default(cuid())
  clientId           String
  projectName        String
  projectType        String    @default("GENERAL") // GENERAL|RESIDENTIAL|COMMERCIAL|RENOVATION|PRODUCT_BUILD|FEATURE_DEVELOPMENT|MAINTENANCE_RETAINER|CONSULTING|MARKETING_CAMPAIGN
  stage              String? // Arch: CONCEPT|SCHEMATIC|DESIGN_DEVELOPMENT|DRAWINGS|APPROVALS|CONSTRUCTION|HANDOVER; Civil: SURVEY|DESIGN|FOUNDATION|STRUCTURE|FINISHING|HANDOVER
  status             String    @default("ACTIVE") // ACTIVE|ON_HOLD|COMPLETED|CANCELLED
  totalContractValue Decimal?
  startDate          DateTime?
  expectedEndDate    DateTime?
  completedDate      DateTime?
  assignedToId       String?
  notes              String?
  // Phase 54F — Marketing Agency depth (marketing_campaigns module flag).
  // Generic, nullable columns on the shared ServiceProject model rather than
  // a parallel "Campaign" entity — same reuse-over-parallel-schema call this
  // project has made repeatedly (appointments, lab orders). Populated only
  // when marketing_campaigns is enabled; every other ServiceProject-using
  // vertical (Architect/Civil/Consultant/Software Agency) simply never sets
  // them.
  targetChannel      String? // e.g. "Google Ads", "Meta Ads", "SEO", "Email", "Social Media", "Content" — free text, not a fixed enum
  deliverableType    String? // e.g. "Campaign Launch", "Creative Asset Set", "Monthly Report", "Website"
  adSpendBudget      Decimal? // Planned/allocated ad spend for this campaign — distinct from totalContractValue (the agency's own fee)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client                     Customer                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo                 Employee?                  @relation("ServiceProjectAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  milestones                 ServiceProjectMilestone[]
  timeEntries                TimeEntry[]
  issues                     Issue[]
  sprints                    Sprint[]
  drawingRevisions           DrawingRevision[]
  siteVisits                 SiteVisit[]
  campaignPerformanceEntries CampaignPerformanceEntry[] // Phase 58 §2 — Marketing Agency
  contentCalendarItems       ContentCalendarItem[] // Phase 58 §2 — Marketing Agency

  @@index([clientId])
  @@index([status])
  @@index([assignedToId])
}

// Phase 58 §2 — Marketing Agency: real campaign performance data entry
// (impressions/clicks/conversions/actual spend per period), distinct from
// ServiceProject.adSpendBudget (the PLANNED budget) — this is what actually
// happened, logged periodically so a real trend/summary can be built,
// instead of the agency having no way to record outcomes at all.
model CampaignPerformanceEntry {
  id          String   @id @default(cuid())
  projectId   String
  periodStart DateTime
  periodEnd   DateTime
  impressions Int?
  clicks      Int?
  conversions Int?
  actualSpend Decimal?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project ServiceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([periodStart])
}

// Phase 58 §2 — Marketing Agency: a real content calendar per campaign,
// instead of tracking upcoming content ad hoc in notes/spreadsheets.
model ContentCalendarItem {
  id            String   @id @default(cuid())
  projectId     String
  scheduledDate DateTime
  contentType   String   @default("SOCIAL_POST") // SOCIAL_POST|BLOG|EMAIL|AD_CREATIVE|VIDEO|OTHER
  title         String
  platform      String?
  status        String   @default("PLANNED") // PLANNED|IN_PROGRESS|PUBLISHED|CANCELLED
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project ServiceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([scheduledDate])
}

// Fresh-audit build (2026-07-12) — Architect real depth. A drawing register
// (which drawing, which revision, current status) is genuine, everyday
// architectural-practice bookkeeping that Consultant/Civil Engineer don't
// share — previously Architect had ZERO fields of its own beyond the
// generic ServiceProject/leads/time_entries scaffold, byte-for-byte
// identical to Civil Engineer's module set.
model DrawingRevision {
  id             String    @id @default(cuid())
  projectId      String
  drawingNumber  String
  title          String
  discipline     String    @default("ARCHITECTURAL") // ARCHITECTURAL|STRUCTURAL|MEP|LANDSCAPE|INTERIOR
  revisionNumber String    @default("A")
  status         String    @default("DRAFT") // DRAFT|ISSUED_FOR_REVIEW|APPROVED|SUPERSEDED
  issuedDate     DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // Phase 58 §2 — links successive revisions of the SAME drawing number into
  // a real chain (Rev A -> Rev B -> Rev C) instead of independent rows a
  // mutable revisionNumber field could silently overwrite. issueNewRevision()
  // is the only path that sets this — it creates a NEW row pointing back at
  // its predecessor and flips the predecessor's status to SUPERSEDED, so the
  // full history stays queryable and comparable.
  supersedesId   String?   @unique
  // Client approval/sign-off trail — WHO approved and WHEN, not just a
  // status label. Required together whenever status moves to APPROVED.
  approvedByName String?
  approvedDate   DateTime?

  project      ServiceProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supersedes   DrawingRevision? @relation("RevisionChain", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy DrawingRevision? @relation("RevisionChain")

  @@index([projectId])
  @@index([status])
  @@index([drawingNumber])
}

// Fresh-audit build (2026-07-12) — Civil Engineer real depth. A site visit
// log (survey/inspection/progress-check findings) is genuine, everyday
// civil-practice bookkeeping distinct from an architect's drawing-issue
// workflow — the actual differentiator this vertical was missing.
model SiteVisit {
  id                String   @id @default(cuid())
  projectId         String
  visitDate         DateTime
  visitType         String   @default("INSPECTION") // SURVEY|INSPECTION|PROGRESS_CHECK|HANDOVER
  findings          String?
  weatherConditions String?
  recordedById      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  // Phase 58 §2 — GPS tagging, captured from the device's real Geolocation
  // API reading at time of logging (with a manual-entry fallback — desktop
  // hardware without a real GPS chip falls back to coarse IP-based
  // geolocation, self-documented by a large locationAccuracy value rather
  // than hidden).
  latitude          Float?
  longitude         Float?
  locationAccuracy  Float? // meters, as reported by the Geolocation API

  project             ServiceProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  recordedBy          Employee?            @relation("SiteVisitRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  materialTestResults MaterialTestResult[]

  @@index([projectId])
  @@index([visitDate])
}

// Phase 58 §2 — structured material-test-result fields (value + pass/fail),
// not buried in SiteVisit's free-text `findings`. result is auto-computed
// server-side ONLY when a real pass/fail threshold (requiredMinValue) is
// supplied alongside the measured value — never guessed otherwise (stays
// PENDING for manual entry, e.g. tests that aren't a simple >= threshold).
model MaterialTestResult {
  id                  String    @id @default(cuid())
  siteVisitId         String
  testType            String // CONCRETE_CUBE_STRENGTH|SOIL_COMPACTION|STEEL_TENSILE|SLUMP_TEST|OTHER
  materialDescription String? // e.g. "M25 grade concrete, Column C4"
  testValue           Float?
  unit                String? // e.g. "MPa", "%", "mm"
  requiredMinValue    Float? // pass threshold, optional
  result              String    @default("PENDING") // PENDING|PASS|FAIL
  testedDate          DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  siteVisit SiteVisit @relation(fields: [siteVisitId], references: [id], onDelete: Cascade)

  @@index([siteVisitId])
}

model ServiceProjectMilestone {
  id              String    @id @default(cuid())
  projectId       String
  milestoneName   String
  milestoneAmount Decimal?
  status          String    @default("UPCOMING") // UPCOMING|IN_PROGRESS|COMPLETED|INVOICED|PAID
  dueDate         DateTime?
  completedDate   DateTime?
  invoiceId       String? // Invoice reference when INVOICED
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project ServiceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

model RetainerAgreement {
  id                 String    @id @default(cuid())
  clientId           String
  assignedToId       String?
  title              String
  retainerType       String    @default("FIXED_FEE") // FIXED_FEE|HOURLY_BUCKET|DELIVERABLE_BASED
  monthlyAmount      Decimal
  billingDay         Int       @default(1) // Day of month to generate invoice (1–28)
  hoursPerMonth      Decimal? // For HOURLY_BUCKET
  deliverables       String? // JSON string for DELIVERABLE_BASED
  status             String    @default("ACTIVE") // ACTIVE|PAUSED|EXPIRED
  startDate          DateTime
  endDate            DateTime?
  notes              String?
  lastInvoicedPeriod String? // Phase 54B — "YYYY-MM" of the last period actually invoiced; recurring, so unlike a one-off invoiceId this is a claim key not a nullable pointer
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client      Customer    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo  Employee?   @relation("RetainerAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  timeEntries TimeEntry[]

  @@index([clientId])
  @@index([status])
  @@index([assignedToId])
}

model Issue {
  id           String    @id @default(cuid())
  projectId    String
  title        String
  description  String?
  priority     String    @default("MED") // HIGH|MED|LOW
  status       String    @default("OPEN") // OPEN|IN_PROGRESS|RESOLVED|CLOSED
  assignedToId String?
  sprintId     String?
  storyPoints  Int? // Phase 58 §2 — Software Agency: basic estimate, feeds burndown/velocity
  reportedDate DateTime  @default(now())
  resolvedDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project    ServiceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo Employee?      @relation("IssueAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  sprint     Sprint?        @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  comments   IssueComment[]
  subtasks   IssueSubtask[]

  @@index([projectId])
  @@index([status])
  @@index([assignedToId])
  @@index([sprintId])
}

// Phase 58 §2 — Software Agency: real issue depth (comments)
model IssueComment {
  id        String   @id @default(cuid())
  issueId   String
  authorId  String?
  body      String
  createdAt DateTime @default(now())

  issue  Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([issueId])
}

// Phase 58 §2 — Software Agency: real issue depth (checklist-style subtasks)
model IssueSubtask {
  id        String   @id @default(cuid())
  issueId   String
  title     String
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
}

model Sprint {
  id           String   @id @default(cuid())
  projectId    String
  sprintNumber Int
  name         String? // "Sprint 1 — MVP Core"
  goal         String?
  startDate    DateTime
  endDate      DateTime
  status       String   @default("PLANNING") // PLANNING|ACTIVE|COMPLETED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project ServiceProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues  Issue[]

  @@unique([projectId, sprintNumber])
  @@index([projectId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 31 — COACHING INSTITUTE / TUITION / ACADEMY
// ─────────────────────────────────────────────────────────────────────────────

model StudentProfile {
  id             String   @id @default(cuid())
  customerId     String   @unique
  rollNumber     String?
  classOrGrade   String
  schoolName     String?
  parentPhone    String?
  enrollmentDate DateTime @default(now())
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([isActive])
}

model CoachingBatch {
  id              String    @id @default(cuid())
  batchName       String
  subjectOrCourse String
  instructorId    String?
  scheduleDays    String    @default("[]") // JSON: ["MON","WED","FRI"]
  scheduleTime    String?
  roomOrLocation  String?
  maxCapacity     Int       @default(20)
  startDate       DateTime
  endDate         DateTime?
  status          String    @default("ACTIVE") // ACTIVE|COMPLETED|CANCELLED
  feePerMonth     Decimal
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  instructor     Employee?                 @relation("CoachingBatchInstructor", fields: [instructorId], references: [id], onDelete: SetNull)
  enrollments    CoachingBatchEnrollment[]
  attendances    CoachingBatchAttendance[]
  performances   Performance[]
  feeRecords     CoachingFeeRecord[]
  syllabusTopics SyllabusTopic[] // Phase 58 §2 — Coaching Institute

  @@index([status])
  @@index([instructorId])
}

// Phase 58 §2 — Coaching Institute: topic-by-topic syllabus coverage per
// batch, so "how much of the syllabus is actually done" is a real tracked
// fact instead of living only in an instructor's head.
model SyllabusTopic {
  id            String    @id @default(cuid())
  batchId       String
  topicName     String
  sequenceOrder Int       @default(0)
  plannedDate   DateTime?
  status        String    @default("PENDING") // PENDING|COMPLETED
  completedDate DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  batch CoachingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
}

model CoachingBatchEnrollment {
  id             String   @id @default(cuid())
  batchId        String
  studentId      String
  enrolledDate   DateTime @default(now())
  // Phase 58 §2 — Coaching Institute: WAITLISTED added. A batch at capacity
  // used to hard-reject any new enrollment; now it enrolls as WAITLISTED
  // instead (excluded from generateMonthlyFees, which only ever queries
  // status: 'ACTIVE' — a waitlisted student is never billed until promoted).
  status         String   @default("ACTIVE") // ACTIVE|WAITLISTED|DROPPED|COMPLETED
  discountType   String   @default("NONE") // NONE|SCHOLARSHIP|SIBLING|REFERRAL|CUSTOM
  discountAmount Decimal  @default(0)
  effectiveFee   Decimal
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  batch      CoachingBatch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student    Customer            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeRecords CoachingFeeRecord[]
  testScores StudentTestScore[] // Phase 54F — real academic test-score tracking, distinct from Performance (below) which is event/recital bookings

  @@unique([batchId, studentId])
  @@index([batchId])
  @@index([studentId])
  @@index([status])
}

model CoachingBatchAttendance {
  id                String   @id @default(cuid())
  batchId           String
  attendanceDate    DateTime
  presentStudentIds String   @default("[]") // JSON array of Customer IDs
  absentStudentIds  String   @default("[]") // JSON array of Customer IDs
  takenById         String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  batch   CoachingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  takenBy Employee?     @relation("CoachingAttendanceTaker", fields: [takenById], references: [id], onDelete: SetNull)

  @@unique([batchId, attendanceDate])
  @@index([batchId])
  @@index([attendanceDate])
}

model CoachingFeeRecord {
  id             String    @id @default(cuid())
  enrollmentId   String
  studentId      String // denormalized from enrollment for direct queries
  batchId        String // denormalized from enrollment for direct queries
  feeMonth       String // "2026-07" format (YYYY-MM)
  dueDate        DateTime?
  baseAmount     Decimal   @default(0) // fee before tax
  taxRate        Decimal   @default(0) // e.g. 18 for 18% GST; 0 = GST-exempt
  taxAmount      Decimal   @default(0) // computed: baseAmount × taxRate / 100
  amountDue      Decimal
  amountReceived Decimal   @default(0)
  status         String    @default("PENDING") // PENDING|PAID|PARTIAL|WAIVED
  paidDate       DateTime?
  notes          String?
  invoiceId      String? // Phase 54B — real GST Invoice generated once, the first time this record reaches PAID (was a shadow ledger with no Invoice link at all before this)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  enrollment CoachingBatchEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  batch      CoachingBatch           @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, feeMonth])
  @@index([batchId])
  @@index([studentId])
  @@index([status])
  @@index([feeMonth])
}

// Event/recital bookings (school function, annual day performance, etc.) —
// despite the model name, this is NOT academic test-score tracking. See
// StudentTestScore below for that; the two are deliberately separate models,
// not a naming overlap to be confused with each other. The renderer already
// labels this "Performances & Recitals" (PerformanceScreen.tsx), which is
// accurate — the model name itself just predates StudentTestScore existing.
model Performance {
  id                      String   @id @default(cuid())
  batchId                 String
  performanceName         String
  date                    DateTime
  venue                   String?
  participatingStudentIds String   @default("[]") // JSON array of Customer IDs
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  batch CoachingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([date])
}

// Phase 54F — real academic performance: test/exam scores per student
// enrollment. Closes the gap the audit found: "performance tracking" only
// ever meant event/recital bookings (Performance, above) — there was no
// subject-wise mark/grade record anywhere despite the feature's name.
model StudentTestScore {
  id            String   @id @default(cuid())
  enrollmentId  String
  testName      String // e.g. "Unit Test 1", "Mid-Term"
  subject       String?
  marksObtained Float
  maxMarks      Float
  testDate      DateTime
  grade         String? // optional letter/grade label, entered manually — not auto-computed (grading scales vary too much per institute to hardcode one)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enrollment CoachingBatchEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([testDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 32 — PHOTOGRAPHY, EVENT MANAGEMENT, REAL ESTATE
// ─────────────────────────────────────────────────────────────────────────────

model ShootBooking {
  id                     String    @id @default(cuid())
  clientId               String
  shootType              String // WEDDING|MATERNITY|NEWBORN|BIRTHDAY|CORPORATE|PRODUCT|PORTFOLIO|REAL_ESTATE|OTHER
  shootDate              DateTime
  shootTime              String?
  shootLocation          String
  estimatedDurationHours Decimal
  deliverableType        String    @default("DIGITAL_ONLY") // DIGITAL_ONLY|PRINT_ALBUM|PRINTS|MIXED
  expectedPhotosCount    Int?
  deliveryDeadline       DateTime?
  photographerIds        String    @default("[]") // JSON array of Employee IDs
  editorAssignedId       String?
  status                 String    @default("INQUIRY") // INQUIRY|CONFIRMED|SHOT|EDITING|DELIVERED|CANCELLED
  finalAmount            Decimal? // Phase 40: agreed billable amount, set once quoted/confirmed — distinct from any rough estimate; required before an invoice can be generated
  invoiceId              String?
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  client     Customer          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  editor     Employee?         @relation("ShootEditor", fields: [editorAssignedId], references: [id], onDelete: SetNull)
  delivery   DeliveryTracker?
  checklist  ShootChecklistItem[] // Phase 58 §2 — Photo Studio: shoot-day equipment/crew checklist
  addOnItems ShootAddOnItem[] // Phase 58 §2 — Photo Studio: itemized add-ons

  @@index([clientId])
  @@index([shootDate])
  @@index([status])
}

model DeliveryTracker {
  id                    String    @id @default(cuid())
  shootBookingId        String    @unique
  proofsSentDate        DateTime?
  selectionReceivedDate DateTime?
  editingStartedDate    DateTime?
  albumProofSentDate    DateTime?
  finalDeliveredDate    DateTime?
  deliveryFormat        String?
  deliveredPhotosCount  Int? // Phase 58 §2 — Photo Studio: actual delivered count, vs. ShootBooking.expectedPhotosCount
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  shootBooking ShootBooking @relation(fields: [shootBookingId], references: [id], onDelete: Cascade)
}

// Phase 58 §2 — Photo Studio: shoot-day equipment/crew checklist, per booking
model ShootChecklistItem {
  id             String   @id @default(cuid())
  shootBookingId String
  category       String   @default("EQUIPMENT") // EQUIPMENT|CREW
  label          String
  isDone         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shootBooking ShootBooking @relation(fields: [shootBookingId], references: [id], onDelete: Cascade)

  @@index([shootBookingId])
}

// Phase 58 §2 — Photo Studio: itemized add-ons (extra prints, album copies,
// etc.) feeding into the final invoiced amount alongside the base package fee.
model ShootAddOnItem {
  id             String   @id @default(cuid())
  shootBookingId String
  description    String
  quantity       Int      @default(1)
  unitPrice      Decimal
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  shootBooking ShootBooking @relation(fields: [shootBookingId], references: [id], onDelete: Cascade)

  @@index([shootBookingId])
}

model EventBooking {
  id                 String    @id @default(cuid())
  clientId           String
  eventName          String
  eventType          String // WEDDING|CORPORATE|BIRTHDAY|CONFERENCE|SOCIAL|POOJA|OTHER
  eventDate          DateTime
  eventEndDate       DateTime?
  venueName          String
  venueAddress       String?
  expectedGuestCount Int?
  clientBudget       Decimal?
  finalAmount        Decimal? // Phase 40: agreed billable amount, set once quoted/confirmed — distinct from clientBudget (a rough pre-booking estimate); required before an invoice can be generated
  status             String    @default("INQUIRY") // INQUIRY|QUOTED|CONFIRMED|IN_PROGRESS|COMPLETED|CANCELLED
  invoiceId          String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client         Customer             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vendorBookings EventVendorBooking[]
  runOfShowItems EventRunOfShowItem[] // Phase 58 §2 — Event Management

  @@index([clientId])
  @@index([eventDate])
  @@index([status])
}

model EventVendorBooking {
  id             String   @id @default(cuid())
  eventId        String
  vendorId       String
  vendorCategory String // CATERING|DECORATION|PHOTOGRAPHY|AV_SOUND|VENUE|ENTERTAINMENT|TRANSPORT|FLOWERS|OTHER
  quotedAmount   Decimal
  // Phase 58 §2 — Event Management: guest-count-to-costing. When
  // pricingType is PER_HEAD, quotedAmount is ALWAYS server-computed from
  // perHeadRate × the event's current expectedGuestCount (never trusted
  // from the client) and kept in sync whenever either input changes — same
  // "recompute on any relevant change, never accept the derived number
  // directly" discipline as Real Estate's coBrokerShareAmount.
  pricingType    String   @default("FLAT") // FLAT|PER_HEAD
  perHeadRate    Decimal?
  advancePaid    Decimal  @default(0)
  status         String   @default("ENQUIRED") // ENQUIRED|BOOKED|CONFIRMED|COMPLETED
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event  EventBooking @relation(fields: [eventId], references: [id], onDelete: Cascade)
  vendor Supplier     @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  @@index([eventId])
  @@index([vendorId])
  @@index([status])
}

// Phase 58 §2 — Event Management: event-day run-of-show/execution timeline,
// distinct from the vendor procurement checklist (EventVendorBooking) above.
model EventRunOfShowItem {
  id               String   @id @default(cuid())
  eventId          String
  scheduledTime    DateTime
  activity         String
  responsibleParty String?
  isDone           Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  event EventBooking @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Property {
  id               String   @id @default(cuid())
  propertyType     String // RESIDENTIAL_FLAT|INDEPENDENT_HOUSE|PLOT|COMMERCIAL_OFFICE|COMMERCIAL_SHOP|WAREHOUSE|AGRICULTURAL
  listingType      String // SALE|RENT|LEASE
  status           String   @default("AVAILABLE") // AVAILABLE|UNDER_NEGOTIATION|SOLD|RENTED|OFF_MARKET
  location         String
  area             Decimal
  floorNumber      Int?
  totalFloors      Int?
  askingPrice      Decimal?
  monthlyRent      Decimal?
  securityDeposit  Decimal?
  ownerClientId    String
  brokeragePercent Decimal?
  photos           String   @default("[]") // JSON: local file paths
  description      String?
  amenities        String   @default("[]") // JSON array of strings
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  owner     Customer          @relation("PropertyOwner", fields: [ownerClientId], references: [id], onDelete: Cascade)
  inquiries PropertyInquiry[]
  deals     PropertyDeal[]

  @@index([status])
  @@index([listingType])
  @@index([ownerClientId])
}

model PropertyInquiry {
  id               String    @id @default(cuid())
  propertyId       String
  buyerClientId    String
  inquiryDate      DateTime  @default(now())
  status           String    @default("SHORTLISTED") // SHORTLISTED|SITE_VISIT_SCHEDULED|NEGOTIATION|DEAL_CLOSED|REJECTED
  notes            String?
  nextFollowUpDate DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  property   Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer      Customer            @relation("InquiryBuyer", fields: [buyerClientId], references: [id], onDelete: Cascade)
  siteVisits PropertySiteVisit[]

  @@index([propertyId])
  @@index([buyerClientId])
  @@index([status])
}

// Phase 58 §2 — Real Estate: structured site-visit scheduling with feedback
// capture, replacing PropertyInquiry.status's bare "SITE_VISIT_SCHEDULED"
// label (previously not backed by any real date/time/outcome record).
model PropertySiteVisit {
  id            String    @id @default(cuid())
  inquiryId     String
  scheduledDate DateTime
  scheduledTime String?
  status        String    @default("SCHEDULED") // SCHEDULED|COMPLETED|CANCELLED|NO_SHOW
  feedback      String?
  interestLevel String? // HIGH|MEDIUM|LOW|NONE — captured post-visit
  completedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  inquiry PropertyInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@index([scheduledDate])
}

model PropertyDeal {
  id                       String    @id @default(cuid())
  propertyId               String
  buyerClientId            String
  sellerClientId           String
  dealValue                Decimal
  brokeragePercent         Decimal
  brokerageAmount          Decimal
  expectedRegistrationDate DateTime?
  status                   String    @default("IN_PROGRESS") // IN_PROGRESS|REGISTERED|FELL_THROUGH
  invoiceId                String?
  notes                    String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  // Phase 58 §2 — co-broker commission-split tracking. coBrokerShareAmount
  // is always computed server-side from brokerageAmount * coBrokerSharePercent
  // / 100 (never entered directly) — this firm's own retained share is
  // brokerageAmount - coBrokerShareAmount, derivable on the fly rather than
  // stored separately (avoids two numbers silently drifting out of sync).
  coBrokerName             String?
  coBrokerSharePercent     Decimal?
  coBrokerShareAmount      Decimal?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer    Customer @relation("DealBuyer", fields: [buyerClientId], references: [id], onDelete: Restrict)
  seller   Customer @relation("DealSeller", fields: [sellerClientId], references: [id], onDelete: Restrict)

  @@index([propertyId])
  @@index([status])
}

// ─── Phase 33 — Car Service, Tailor Boutique, Pest Control ────────────────────

model CarJobCard {
  id                 String    @id @default(cuid())
  jobNumber          String    @unique
  clientId           String
  vehicleNumber      String
  vehicleMake        String
  vehicleModel       String
  vehicleYear        Int?
  vehicleType        String    @default("4W") // 2W|4W|COMMERCIAL|OTHER
  kmIn               Int?
  kmOut              Int?
  serviceAdvisorId   String?
  technicianIds      String    @default("[]") // JSON array of Employee IDs
  serviceItems       String    @default("[]") // JSON: [{name,quantity,unitPrice}]
  partsItems         String    @default("[]") // JSON: [{name,partNumber?,quantity,unitPrice}]
  laborTotal         Decimal   @default(0)
  partsTotal         Decimal   @default(0)
  estimatedDelivery  DateTime?
  deliveredDate      DateTime?
  status             String    @default("RECEIVED") // RECEIVED|INSPECTION|IN_PROGRESS|WAITING_PARTS|READY|DELIVERED|CANCELLED
  invoiceId          String?
  notes              String?
  internalNotes      String?
  // Phase 58 §2 — Car Service Center: next-service-due tracking by date or
  // odometer. Both nullable/independent — a shop may recommend either or
  // both. There is no separate Vehicle master table (vehicleNumber is a
  // free-standing field on each job card, same as every other field here),
  // so "due for service" is always computed from the MOST RECENT job card
  // for a given vehicleNumber, not a mutable running counter.
  nextServiceDueDate DateTime?
  nextServiceDueKm   Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client         Customer  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceAdvisor Employee? @relation("CarJobAdvisor", fields: [serviceAdvisorId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status])
  @@index([vehicleNumber])
  @@index([createdAt])
}

model MeasurementRecord {
  id             String   @id @default(cuid())
  clientId       String
  chest          Decimal?
  waist          Decimal?
  hips           Decimal?
  shoulder       Decimal?
  neck           Decimal?
  sleeve         Decimal?
  inseam         Decimal?
  outseam        Decimal?
  thigh          Decimal?
  height         Decimal?
  // Phase 48 — the generic unisex set above (chest/waist/shoulder/sleeve
  // etc.) is not sufficient for accurate blouse tailoring (needs neck
  // depth/armhole/length) and shirt tailoring is missing a real cuff
  // measurement (distinct from sleeve length) — confirmed via this phase's
  // own audit, not assumed. All optional; pant is already adequately
  // covered by the existing waist/hips/inseam/outseam/thigh set.
  armhole        Decimal?
  frontNeckDepth Decimal?
  backNeckDepth  Decimal?
  garmentLength  Decimal?
  cuff           Decimal?
  notes          String?
  takenById      String?
  recordDate     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client          Customer         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  takenBy         Employee?        @relation("MeasurementTakenBy", fields: [takenById], references: [id], onDelete: SetNull)
  tailoringOrders TailoringOrder[]

  @@index([clientId])
  @@index([recordDate])
}

model TailoringOrder {
  id                  String    @id @default(cuid())
  orderNumber         String    @unique
  clientId            String
  measurementRecordId String?
  garmentType         String // SHIRT|PANT|SUIT|KURTA|SALWAR_KAMEEZ|BLOUSE|LEHENGA|SAREE_BLOUSE|JACKET|OTHER
  // Phase 48 — nullable/optional, no default forced. gender: MENS|WOMENS.
  // styleRegion: INDIAN|WESTERN.
  gender              String?
  styleRegion         String?
  fabricDescription   String?
  fabricSupplied      String    @default("CLIENT") // CLIENT|SHOP
  quantity            Int       @default(1)
  unitPrice           Decimal   @default(0)
  totalAmount         Decimal   @default(0)
  advancePaid         Decimal   @default(0)
  trialDate           DateTime?
  deliveryDate        DateTime?
  deliveredDate       DateTime?
  status              String    @default("RECEIVED") // RECEIVED|IN_CUTTING|IN_STITCHING|TRIAL_SCHEDULED|ALTERATIONS|READY|DELIVERED|CANCELLED
  assignedToId        String?
  invoiceId           String?
  specialInstructions String?
  notes               String?
  // Phase 58 §2 — Tailor Boutique: the trial/fitting date used to be a bare
  // field with no real reminder behind it. A real `Appointment` gets
  // created and linked here so it rides the SAME 24h/2h WhatsApp reminder
  // pipeline every other appointment type already uses — no new reminder
  // mechanism invented. trialDate stays in sync (denormalized) for any
  // existing reader (e.g. reports) that only ever expected a bare date.
  trialAppointmentId  String?   @unique
  // Fabric-stock deduction — only meaningful when fabricSupplied='SHOP'.
  // Set once via a dedicated action (setOrderFabric), mirroring the
  // add/remove pair pattern used for Repair's JobCardPart — not a plain
  // mutable field, since changing it after stock has been deducted needs
  // an explicit restore step first.
  fabricProductId     String?
  fabricQuantity      Float?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  client           Customer           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  measurement      MeasurementRecord? @relation(fields: [measurementRecordId], references: [id], onDelete: SetNull)
  assignedTo       Employee?          @relation("TailoringAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  trialAppointment Appointment?       @relation(fields: [trialAppointmentId], references: [id], onDelete: SetNull)
  fabricProduct    Product?           @relation(fields: [fabricProductId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status])
  @@index([deliveryDate])
  @@index([createdAt])
  @@index([trialAppointmentId])
  @@index([fabricProductId])
}

model PestServiceContract {
  id                 String    @id @default(cuid())
  contractNumber     String    @unique
  clientId           String
  propertyAddress    String
  propertyType       String    @default("RESIDENTIAL") // RESIDENTIAL|COMMERCIAL|INDUSTRIAL
  pestTypes          String    @default("[]") // JSON: ["COCKROACHES","RODENTS","TERMITES","ANTS","MOSQUITOES","BEDBUGS","OTHER"]
  serviceFrequency   String    @default("QUARTERLY") // MONTHLY|QUARTERLY|HALF_YEARLY|YEARLY|ONE_TIME
  startDate          DateTime
  endDate            DateTime?
  contractValue      Decimal
  status             String    @default("ACTIVE") // ACTIVE|EXPIRED|CANCELLED|PENDING
  assignedToId       String?
  notes              String?
  lastInvoicedPeriod String? // "YYYY-MM" of the last period actually invoiced for the recurring contractValue — contractValue was previously never billed at all, only ad-hoc job sheets invoiced
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  client     Customer       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo Employee?      @relation("PestContractAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  jobSheets  PestJobSheet[]

  @@index([clientId])
  @@index([status])
  @@index([assignedToId])
}

model PestJobSheet {
  id              String    @id @default(cuid())
  jobNumber       String    @unique
  contractId      String?
  clientId        String
  visitDate       DateTime
  scheduledTime   String?
  technicianIds   String    @default("[]") // JSON array of Employee IDs
  pesticideUsed   String?
  areasServiced   String    @default("[]") // JSON: ["Kitchen","Store Room"]
  treatmentType   String    @default("SPRAY") // SPRAY|GEL|FUMIGATION|TRAP|BAIT|COMBINED
  jobAmount       Decimal   @default(0)
  status          String    @default("SCHEDULED") // SCHEDULED|IN_PROGRESS|COMPLETED|CANCELLED
  completedDate   DateTime?
  followUpDate    DateTime?
  clientSignature Boolean   @default(false)
  invoiceId       String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  contract       PestServiceContract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)
  client         Customer                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  pesticideLines PestJobSheetPesticide[] // Phase 58 §2

  @@index([contractId])
  @@index([clientId])
  @@index([status])
  @@index([visitDate])
}

// Phase 58 §2 — Pest Control: structured pesticide dosage/quantity per job
// sheet visit, replacing the single free-text PestJobSheet.pesticideUsed
// field (kept as-is for a quick summary/search string). A visit commonly
// uses more than one chemical across different areas, so this is a real
// add/remove ledger (mirrors JobCardPart), not a set-once field. productId
// is OPTIONAL — unlike JobCardPart, not every shop tracks its pesticide
// stock as an Inventory Product; when it IS linked, adding a line deducts
// real stock via the same inventoryService.reduceStockTx every other
// consumption path uses, and removing restores it.
model PestJobSheetPesticide {
  id            String   @id @default(cuid())
  jobSheetId    String
  productId     String?
  pesticideName String
  quantityUsed  Float
  unit          String   @default("ML") // ML|L|G|KG|OTHER
  dosageNote    String? // e.g. "2% dilution, 50ml per 5L water"
  targetPest    String? // e.g. "Cockroach", "Termite"
  createdAt     DateTime @default(now())

  jobSheet PestJobSheet @relation(fields: [jobSheetId], references: [id], onDelete: Cascade)
  product  Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([jobSheetId])
  @@index([productId])
}

// ─── Phase 34 — Placement Agency ──────────────────────────────────────────────

model Candidate {
  id                 String    @id @default(cuid())
  candidateNumber    String    @unique
  fullName           String
  email              String?
  phone              String?
  currentJobTitle    String?
  currentEmployer    String?
  totalExperience    Decimal? // years
  skills             String    @default("[]") // JSON: ["React","TypeScript"]
  preferredLocations String    @default("[]") // JSON: ["Bangalore","Mumbai"]
  educationSummary   String?
  resumeNotes        String?
  expectedSalary     Decimal?
  currentSalary      Decimal?
  availableFrom      DateTime?
  status             String    @default("ACTIVE") // ACTIVE|PLACED|ON_HOLD|BLACKLISTED
  source             String    @default("WALKIN") // REFERRAL|LINKEDIN|WEBSITE|WALKIN|OTHER
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  placements      Placement[]
  interviewRounds InterviewRound[] // Phase 58 §2 — Placement Agency

  @@index([status])
  @@index([createdAt])
  @@index([fullName])
}

model JobOrder {
  id                String    @id @default(cuid())
  orderNumber       String    @unique
  clientId          String // the hiring company (Customer)
  jobTitle          String
  jobDescription    String?
  requiredSkills    String    @default("[]") // JSON: ["Java","Spring Boot"]
  experienceMin     Decimal? // years
  experienceMax     Decimal?
  salaryBudgetMin   Decimal?
  salaryBudgetMax   Decimal?
  location          String?
  numberOfPositions Int       @default(1)
  status            String    @default("OPEN") // OPEN|IN_PROGRESS|ON_HOLD|CLOSED|CANCELLED
  targetDate        DateTime?
  commissionType    String    @default("PERCENTAGE") // PERCENTAGE|FIXED
  commissionValue   Decimal   @default(0)
  // Phase 58 §2 — Placement Agency: fee-agreement/replacement-guarantee
  // terms per job order. Plain String/Int, deliberately NOT Decimal — this
  // phase has repeatedly hit a real bug where a new Decimal column gets
  // added to a model without updating its IPC serializer; a free-text terms
  // field and a plain day-count sidestep that whole bug class outright.
  feeAgreementTerms        String?
  replacementGuaranteeDays Int?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  client          Customer         @relation("JobOrderClient", fields: [clientId], references: [id], onDelete: Cascade)
  placements      Placement[]
  interviewRounds InterviewRound[] // Phase 58 §2 — Placement Agency

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

// Phase 58 §2 — Placement Agency: interview-round tracking as a real
// sub-record of a candidate/job-order pairing (stage, date, per-round
// client feedback), distinct from Placement — which only exists once an
// actual offer/join happens.
model InterviewRound {
  id               String    @id @default(cuid())
  candidateId      String
  jobOrderId       String
  roundNumber      Int
  roundType        String    @default("PHONE_SCREEN") // PHONE_SCREEN|TECHNICAL|HR|FINAL|OTHER
  scheduledDate    DateTime?
  status           String    @default("SCHEDULED") // SCHEDULED|COMPLETED|PASSED|REJECTED|NO_SHOW
  interviewerName  String?
  clientFeedback   String?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOrder  JobOrder  @relation(fields: [jobOrderId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([jobOrderId])
  @@index([status])
}

model Placement {
  id               String   @id @default(cuid())
  placementNumber  String   @unique
  candidateId      String
  jobOrderId       String
  clientId         String // hiring company — denormalized for billing
  joiningDate      DateTime
  offeredSalary    Decimal
  commissionAmount Decimal  @default(0)
  invoiceId        String?
  status           String   @default("OFFERED") // OFFERED|JOINED|INVOICED|CANCELLED
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobOrder  JobOrder  @relation(fields: [jobOrderId], references: [id], onDelete: Cascade)
  client    Customer  @relation("PlacementClient", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([jobOrderId])
  @@index([clientId])
  @@index([status])
  @@index([joiningDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 37 — LOGISTICS & SUPPLY CHAIN MODULE
// ─────────────────────────────────────────────────────────────────────────────

model Vehicle {
  id            String   @id @default(cuid())
  vehicleNumber String   @unique
  vehicleType   String // TRUCK, TEMPO, VAN, BIKE, AUTO
  ownerType     String   @default("OWN") // OWN, HIRED, 3PL
  driverName    String?
  driverPhone   String?
  capacity      Float?
  capacityUnit  String   @default("KG")
  status        String   @default("AVAILABLE") // AVAILABLE, IN_TRANSIT, MAINTENANCE, RETIRED
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shipments Shipment[]
  challans  DeliveryChallan[]

  @@index([status])
}

model Carrier {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   @default("COURIER") // COURIER, TRANSPORT, 3PL, OWN_FLEET
  phone     String?
  email     String?
  gstNumber String?
  ratePerKg Float?
  ratePerKm Float?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shipments     Shipment[]
  freightLedger FreightLedger[]

  @@index([isActive])
}

model Shipment {
  id                 String    @id @default(cuid())
  shipmentNumber     String    @unique
  shipmentType       String    @default("OUTBOUND") // OUTBOUND, INBOUND, INTERNAL
  referenceType      String? // INVOICE, PRODUCTION_ORDER, PURCHASE_ORDER, MANUAL
  referenceId        String?
  referenceNumber    String?
  originAddress      String?
  destinationAddress String
  customerId         String?
  customerName       String?
  supplierId         String?
  supplierName       String?
  carrierId          String?
  vehicleId          String?
  trackingNumber     String?
  freightAmount      Float     @default(0)
  freightPaidBy      String    @default("SENDER") // SENDER, RECEIVER, THIRD_PARTY
  weight             Float?
  weightUnit         String    @default("KG")
  packages           Int       @default(1)
  status             String    @default("PENDING")
  scheduledDate      DateTime?
  readyAt            DateTime?
  inTransitAt        DateTime?
  outForDeliveryAt   DateTime?
  expectedDelivery   DateTime?
  deliveredAt        DateTime?
  challanNumber      String?
  ewayBillNumber     String?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  carrier       Carrier?           @relation(fields: [carrierId], references: [id])
  vehicle       Vehicle?           @relation(fields: [vehicleId], references: [id])
  items         ShipmentItem[]
  grns          GoodsReceiptNote[]
  challans      DeliveryChallan[]
  freightLedger FreightLedger[]
  // Phase 58 §2 — Distributor's route/beat planning. The top-level
  // destinationAddress/customerId above stay exactly as they were (the
  // "primary" stop, backward compatible with every existing single-stop
  // shipment) — stops is an ADDITIVE list of further beat points on the
  // same run. Vehicle.status availability stays keyed off the whole
  // Shipment (a vehicle is "in transit" for the entire beat, not per stop)
  // — deliberately NOT modeled per-stop, matching how status transitions
  // already worked before this feature existed.
  stops         ShipmentStop[]

  @@index([status])
  @@index([carrierId])
  @@index([vehicleId])
  @@index([scheduledDate])
  @@index([createdAt])
}

model ShipmentItem {
  id           String  @id @default(cuid())
  shipmentId   String
  productId    String?
  productName  String
  quantity     Float
  unit         String  @default("PCS")
  unitValue    Float   @default(0)
  totalValue   Float   @default(0)
  batchNumber  String?
  serialNumber String?
  notes        String?
  // Phase 58 §2 — which beat stop this line is destined for. Nullable —
  // every pre-existing shipment (and any line not assigned to a specific
  // stop) stays attributed to the shipment's own primary destination.
  stopId       String?

  shipment Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  stop     ShipmentStop? @relation(fields: [stopId], references: [id], onDelete: SetNull)

  @@index([shipmentId])
  @@index([stopId])
}

// Phase 58 §2 — a beat/route stop. sequenceNumber is assigned in add-order
// (the order a dispatcher builds the run), not separately reorderable in
// v1 — real, sufficient sequencing for "visit these N customers on this
// trip", not a route-optimization feature.
model ShipmentStop {
  id                 String    @id @default(cuid())
  shipmentId         String
  sequenceNumber     Int
  customerId         String?
  customerName       String?
  destinationAddress String
  status             String    @default("PENDING") // PENDING | DELIVERED | SKIPPED
  deliveredAt        DateTime?
  notes              String?
  createdAt          DateTime  @default(now())

  shipment Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    ShipmentItem[]

  @@index([shipmentId])
  @@index([customerId])
}

model GoodsReceiptNote {
  id              String    @id @default(cuid())
  grnNumber       String    @unique
  supplierId      String?
  supplierName    String
  purchaseOrderId String?
  shipmentId      String?
  receivedDate    DateTime  @default(now())
  invoiceNumber   String?
  invoiceDate     DateTime?
  totalValue      Float     @default(0)
  status          String    @default("DRAFT") // DRAFT, VERIFIED, POSTED, REVERSED
  postedAt        DateTime?
  reversedAt      DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchaseOrder PurchaseOrder? @relation("GRNPurchaseOrder", fields: [purchaseOrderId], references: [id])
  shipment      Shipment?      @relation(fields: [shipmentId], references: [id])
  items         GRNItem[]

  @@index([purchaseOrderId])
  @@index([status])
  @@index([receivedDate])
}

model GRNItem {
  id            String    @id @default(cuid())
  grnId         String
  productId     String?
  rawMaterialId String?
  itemName      String
  orderedQty    Float?
  receivedQty   Float
  rejectedQty   Float     @default(0)
  unit          String    @default("PCS")
  unitCost      Float     @default(0)
  totalCost     Float     @default(0)
  batchNumber   String?
  expiryDate    DateTime?
  notes         String?

  grn GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)

  @@index([grnId])
}

model DeliveryChallan {
  id              String    @id @default(cuid())
  challanNumber   String    @unique
  challanType     String    @default("DELIVERY") // DELIVERY, RETURNABLE, BRANCH_TRANSFER
  customerId      String?
  customerName    String
  customerAddress String?
  shipmentId      String?
  invoiceId       String?
  vehicleId       String?
  driverName      String?
  driverPhone     String?
  dispatchDate    DateTime?
  expectedReturn  DateTime?
  returnedAt      DateTime?
  status          String    @default("DRAFT") // DRAFT, ISSUED, DELIVERED, RETURNED
  totalValue      Float     @default(0)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shipment Shipment?     @relation(fields: [shipmentId], references: [id])
  invoice  Invoice?      @relation("ChallanInvoice", fields: [invoiceId], references: [id])
  vehicle  Vehicle?      @relation(fields: [vehicleId], references: [id])
  items    ChallanItem[]

  @@index([status])
  @@index([invoiceId])
  @@index([shipmentId])
}

model ChallanItem {
  id          String  @id @default(cuid())
  challanId   String
  productId   String?
  productName String
  quantity    Float
  unit        String  @default("PCS")
  unitValue   Float   @default(0)
  totalValue  Float   @default(0)
  returnedQty Float   @default(0)
  notes       String?

  challan DeliveryChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)

  @@index([challanId])
}

model FreightLedger {
  id              String    @id @default(cuid())
  shipmentId      String?
  carrierId       String?
  carrierName     String
  referenceNumber String?
  amount          Float
  paidDate        DateTime?
  paidBy          String    @default("CASH") // CASH, BANK, CREDIT
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shipment Shipment? @relation(fields: [shipmentId], references: [id])
  carrier  Carrier?  @relation(fields: [carrierId], references: [id])

  @@index([carrierId])
  @@index([shipmentId])
  @@index([paidDate])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// JEWELLERY VERTICAL (fresh-audit build, 2026-07-12)
// ─────────────────────────────────────────────────────────────────────────────

// Owner-updated today's metal rate — one row per metalType+purity combination
// (22K gold and 18K gold trade at genuinely different per-gram rates, not a
// single "gold rate"). Product pricing at billing time always reads the
// CURRENT row for the item's own metalType+purity; historical invoices keep
// their own already-computed unitPrice, so a rate change never retroactively
// alters a past sale.
model MetalRate {
  id          String   @id @default(cuid())
  metalType   String // 'GOLD' | 'SILVER' | 'PLATINUM'
  purity      String // "22K"/"18K"/"916"/"999" — matches Product.purity's free-text convention
  ratePerGram Float
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@unique([metalType, purity])
}

// Old-gold/silver exchange (buyback / trade-in) — standalone record-keeping,
// deliberately NOT atomically wired into billing.service.ts's invoice
// creation (that function is the single most money-critical, most-tested
// path in this codebase; adding a new money-affecting side-channel to it is
// a correctness risk this scope doesn't need to take). A jeweller computes
// the exchange value here, then applies it as an ordinary invoice-level
// discount on the new-purchase invoice through the ALREADY-existing,
// already-tested globalDiscount mechanism — invoiceId is set afterward
// purely so the exchange record shows which sale it was applied against.
model MetalExchange {
  id              String   @id @default(cuid())
  exchangeNumber  String   @unique
  customerId      String?
  customerName    String? // snapshot for walk-in exchanges with no Customer record
  metalType       String // 'GOLD' | 'SILVER' | 'PLATINUM'
  purity          String
  grossWeight     Float
  deductionWeight Float    @default(0) // wastage/impurity deduction subtracted before pricing
  netWeight       Float // grossWeight - deductionWeight, the actually-priced weight
  ratePerGram     Float // rate used at the time of this exchange (snapshotted, not a live FK — same reasoning invoice line items snapshot their own price)
  valueGiven      Float // netWeight * ratePerGram, the credit given to the customer
  invoiceId       String? // set once this credit is applied against a purchase invoice
  notes           String?
  createdAt       DateTime @default(now())
  createdById     String?

  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([invoiceId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// AI ASSISTANT (Phase 57)
// ─────────────────────────────────────────────────────────────────────────────
// Local-only audit log of AI questions — never transmitted anywhere, respects
// the same audit-log access permissions as the rest of the app (see
// AI_ASSISTANT_MASTER_PROMPT.md Section 4/5.7, PHASE_57_TECHNICAL_SPEC.md
// Section 4). Additive-only model, no existing table touched.
model AiQueryLog {
  id              String   @id @default(cuid())
  userId          String?
  question        String // raw user text, for the owner's own audit review
  matchedTemplate String? // e.g. "sales.totalToday", null if out_of_scope/no-match
  matchedCategory String // sales | inventory | customers | suppliers | credit | finance | vertical | out_of_scope
  success         Boolean // false if refusal/fallback fired
  executionTimeMs Int
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}
