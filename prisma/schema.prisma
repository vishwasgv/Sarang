  tokenNumber   Int
  patientName   String
  age           String?
  gender        String?
  phone         String?
  appointmentId String?   @unique
  status        String    @default("WAITING") // WAITING | CALLED | SEEN | SKIPPED
  calledAt      DateTime?
  seenAt        DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@unique([queueDate, tokenNumber])
  @@index([queueDate, status])
  @@index([appointmentId])
}

