model ToothRecord {
  id           String   @id @default(cuid())
  patientId    String
  toothNumber  Int // FDI: 11-18,21-28,31-38,41-48 (perm); 51-55,61-65,71-75,81-85 (deciduous)
  surface      String   @default("[]") // JSON: ["BUCCAL","LINGUAL","MESIAL","DISTAL","OCCLUSAL"]
  condition    String   @default("SOUND") // SOUND|CARIES|FILLED|MISSING|CROWN|BRIDGE_ABUTMENT|IMPLANT|ROOT_CANAL|EXTRACTION_SITE|FRACTURE
  notes        String?
  recordedDate DateTime @default(now())
  recordedById String?
  updatedAt    DateTime @updatedAt

  patient    Customer             @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedBy Employee?            @relation("ToothRecordRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)
  history    ToothRecordHistory[]

  @@unique([patientId, toothNumber])
  @@index([patientId])
  @@index([condition])
}

// Phase 58 §2 — Dental Clinic: ToothRecord above is a single row per
// (patientId, toothNumber) that every save OVERWRITES — no way to see a
// tooth's progression across visits. This is an ADDITIONAL append-only
// ledger alongside it (never replacing it — ToothRecord stays the fast
// "current state" read the chart itself uses), same "ledger alongside the
// aggregate" pattern as RawMaterialBatch/ProductBatch: one new row is
// written every time upsertTooth() saves, snapshotting exactly what was
// saved, so the tooth's real history is a real queryable timeline.
model ToothRecordHistory {
  id            String   @id @default(cuid())
  toothRecordId String
  condition     String
  surface       String   @default("[]")
  notes         String?
  recordedDate  DateTime
  recordedById  String?
  createdAt     DateTime @default(now())

  toothRecord ToothRecord @relation(fields: [toothRecordId], references: [id], onDelete: Cascade)
  recordedBy  Employee?   @relation("ToothRecordHistoryRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([toothRecordId])
}

model TreatmentPlan {
