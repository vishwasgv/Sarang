generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// BUSINESS PROFILE
// ─────────────────────────────────────────────────────────────────────────────
model BusinessProfile {
  id                      String   @id @default(cuid())
  businessName            String
  businessType            String
  businessCategory        String   @default("PRODUCT") // PRODUCT | SERVICE
  serviceTemplateType     String? // e.g. VET_CLINIC, GP_CLINIC
  clinicSpecialty         String? // Phase 54B — free text, e.g. "Pediatrics", "Orthopedics", "ENT", "Ophthalmology" — SPECIALIST_CLINIC's own real identity, not a fixed enum (matches ServiceCatalog.category's free-text precedent)
  languageLock            String   @default("multi") // multi | en
  ownerName               String?
  email                   String?
  phone                   String?
  address                 String?
  city                    String?
  state                   String?
  country                 String   @default("IN")
  postalCode              String?
  currencyCode            String   @default("INR")
  currencySymbol          String   @default("₹")
  taxModel                String   @default("GST")
  taxNumber               String?
  // Phase 58 §2 — Pharmacy regulatory identifier, same flat/nullable shape
  // as clinicSpecialty above — free text (drug-license format varies by
  // jurisdiction), only meaningful/shown for PHARMACY.
  drugLicenseNumber       String?
  upiId                   String?
  website                 String?
  logoPath                String?
  showLogoOnDashboard     Boolean  @default(false)
  enableDocumentWatermark Boolean  @default(false)
  timezone                String   @default("Asia/Kolkata")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id             String    @id @default(cuid())
  fullName       String
  email          String?
  phone          String?
  username       String    @unique
  passwordHash   String
  roleId         String
  isActive       Boolean   @default(true)
  lastLogin      DateTime?
  sessionToken   String?   @unique
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  role               Role                @relation(fields: [roleId], references: [id])
  auditLogs          AuditLog[]
  aiQueryLogs        AiQueryLog[]
  invoices           Invoice[]           @relation("InvoiceCreatedBy")
  expenses           Expense[]           @relation("ExpenseCreatedBy")
  payments           Payment[]           @relation("PaymentRecordedBy")
  stockMovements     InventoryMovement[] @relation("MovementCreatedBy")
  assignedProjects   Project[]           @relation("ProjectAssignedTo")
  assignedTickets    ServiceTicket[]     @relation("TicketAssignedTo")
  assignedJobCards   JobCard[]           @relation("JobCardAssignedTo")
  workLogs           WorkLog[]
  bloodIssuesHandled BloodIssue[]        @relation("BloodIssueIssuedBy") // Phase 51
  issueComments      IssueComment[] // Phase 58 §2 — Software Agency
}

model Role {
  id          String   @id @default(cuid())
  roleName    String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]
}

model Permission {
  id             String   @id @default(cuid())
  permissionKey  String   @unique
  permissionName String
  description    String?
  createdAt      DateTime @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────────────────────────────────────
model ProductCategory {
  id               String   @id @default(cuid())
  name             String
  description      String?
  parentCategoryId String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]
}

model Product {
  id                     String    @id @default(cuid())
  categoryId             String?
  sku                    String?   @unique
  barcode                String?   @unique
  hsnCode                String?
  productName            String
  description            String?
  productType            String    @default("STANDARD")
  unit                   String    @default("PCS")
  costPrice              Float     @default(0)
  sellingPrice           Float
  // Phase 58 §2 — Maximum Retail Price (Indian retail convention): the
  // printed/legal ceiling price, distinct from sellingPrice (the actual
  // billed price, which may sit at or below MRP). Nullable — only
  // meaningful for retail-style businesses that print it, no effect
  // elsewhere.
  mrp                    Float?
  taxRate                Float     @default(0)
  imagePath              String?
  isActive               Boolean   @default(true)
  // Phase 48 — MENS|WOMENS|UNISEX. Nullable/optional, no default forced —
  // only meaningful for apparel-style businesses (surfaced in the UI when
  // variant_tracking is enabled, CLOTHING/FOOTWEAR's default flag).
  gender                 String?
  // Phase 58 §2 (2026-07-17) — Restaurant's "86 today" (industry term for a
  // menu item temporarily unavailable, distinct from permanently
  // deactivating it via isActive). Derived/computed at read time against
  // "now" — never a stored boolean needing a daily-reset job — so it
  // self-clears the moment this timestamp passes, same "derive, don't store
  // a running counter" philosophy as getRetainerHoursUsage. Nullable/unused
  // by every other vertical.
  unavailableUntil       DateTime?
  // Phase 58 §2 — Pharmacy Schedule H/H1 prescription-only medicine flag.
  // Nullable-equivalent default false, unused by every other vertical —
  // when true, billing.service.ts requires a prescription snapshot
  // (patient/doctor/date) on the InvoiceItem before the sale is allowed.
  isPrescriptionRequired Boolean   @default(false)
  // Phase 58 §2 — generic reorder-automation field (not Pharmacy-specific,
  // though Pharmacy is the vertical that motivated it): which supplier to
  // draft a Purchase Order against when this product's stock is low. Null
  // means "no default" — generateReorderDraftPOs() in
  // purchase-order.service.ts skips a low-stock product with no default
  // supplier rather than guessing.
  defaultSupplierId      String?
  // Phase 58 §2 — Agri Inputs category-specific expiry alert lead time. Null
  // means "use the generic default (30 days)" — see product.validation.ts's
  // comment for why this needs to vary by category (seeds/fertilizer vs.
  // pharmacy-shaped medicines). Generic field, not Agri-specific.
  expiryAlertLeadDays    Int?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // Phase 38: loose/weight-based billing (opt-in, off by default — see barcode_generation/loose_billing TemplateModule flags)
  sellByWeight          Boolean   @default(false)
  weightUnit            String?
  pricePerWeightUnit    Float?
  // Phase 58 §2 — Hardware's carton/box-to-loose-piece conversion. A
  // different shape from sellByWeight above (discrete integer pack size,
  // not a continuous fraction of the same stocking unit) — this product is
  // STOCKED and SOLD in the base `unit` (e.g. "PCS") at all times;
  // Inventory.quantity never changes meaning. unitsPerPack only converts
  // how many base units a single purchased pack/carton/box contains, so
  // "received 10 boxes of 50" becomes a single addStock({quantity: 500})
  // call — every existing inventory-quantity read site (billing stock
  // check, low-stock alerts, valuation) needs zero changes.
  sellByPack            Boolean   @default(false)
  packUnit              String? // e.g. "BOX", "CARTON", "CASE"
  unitsPerPack          Float?
  barcodeSource         String?
  // Compact sequential reference (0-99999) embedded in weight-embedded barcode labels for this
  // product — distinct from Product.barcode (which may be a real manufacturer code, or absent).
  // Assigned once, lazily, the first time this product is configured for loose billing.
  looseItemCode         Int?      @unique
  // A regular (non-weight) barcode label prints a price as plain text at print
  // time, but the barcode itself only ever encodes identity — so the *charge*
  // at checkout is always correct (live price lookup), but the *printed
  // sticker* goes stale if the price changes and nobody reprints it. These two
  // fields let updateProduct warn "you changed the price, and a label was
  // printed before at a different price — you may want to reprint the shelf
  // tag" — the same idea as the weight-embedded reprint warning, generalized
  // to every product, not just loose-billed ones.
  lastLabelPrintedAt    DateTime?
  lastLabelPrintedPrice Float?

  // Phase 54G — Rental. Additive, off by default (isRentable: false) — no
  // effect on any non-rental business. rentalRates is a JSON array
  // [{basis:'HOUR'|'DAY'|'WEEK'|'MONTH'|'YEAR', amount:number}] since a
  // rentable item's price genuinely varies by how long it's booked for, not
  // a single sellingPrice the way a sale does.
  isRentable            Boolean @default(false)
  rentalTrackingType    String? // 'UNIT' | 'BULK'
  rentalRates           String  @default("[]")
  rentalSecurityDeposit Float?

  // Jewellery vertical (fresh-audit build, 2026-07-12) — additive, off by
  // default (metalType null). A jewellery item's real sale price isn't the
  // static sellingPrice every other product uses — it's netWeight × today's
  // metal rate (MetalRate) + a making charge, computed at billing time, same
  // "compute at checkout, not at product-save time" reasoning loose/weight
  // billing already established for Product.pricePerWeightUnit.
  metalType         String? // 'GOLD' | 'SILVER' | 'PLATINUM'
  purity            String? // "22K"/"18K"/"916"/"999" — free text, purity conventions vary (karat vs. fineness) by market
  hallmarkNumber    String? // BIS HUID (India) or equivalent
  grossWeight       Float? // grams, item as a whole including stones
  stoneWeight       Float? // grams, deducted from grossWeight — metal is only ever priced on netWeight
  netWeight         Float? // grams, the metal-only weight actually priced
  makingChargeType  String? // 'FIXED' | 'PER_GRAM' | 'PERCENTAGE'
  makingChargeValue Float?

  category                  ProductCategory?          @relation(fields: [categoryId], references: [id])
  defaultSupplier           Supplier?                 @relation("ProductDefaultSupplier", fields: [defaultSupplierId], references: [id], onDelete: SetNull)
  inventory                 Inventory?
  movements                 InventoryMovement[]
  jobCardParts              JobCardPart[] // Phase 58 §2 — Repair
  tailoringOrdersAsFabric   TailoringOrder[] // Phase 58 §2 — Tailor Boutique
  pestJobSheetPesticides    PestJobSheetPesticide[] // Phase 58 §2 — Pest Control
  invoiceItems              InvoiceItem[]
  purchaseItems             PurchaseOrderItem[]
  recipeItems               RecipeItem[]
  variants                  ProductVariant[]
  batches                   ProductBatch[]
  serials                   ProductSerial[]
  bom                       BillOfMaterial?
  productionOrders          ProductionOrder[]
  dispatchRecords           DispatchRecord[]
  labelPrintLogs            LabelPrintLog[]
  rentalUnits               RentalUnit[]
  rentalBookingItems        RentalBookingItem[]
  classPrices               CustomerClassPrice[] // Phase 58 §2 — Distributor customer-class pricing
  repairTickets             RepairTicket[] // Phase 58 §2 — Electronics repair/RMA
  bomComponentUsages        BillOfMaterialItem[]      @relation("BomComponentProduct") // Phase 58 §2 — Manufacturing multi-level BOM
  productionComponentUsages ProductionMaterialUsage[] @relation("ProductionComponentUsage") // Phase 58 §2 — Manufacturing multi-level BOM

  @@index([productName])
  @@index([isActive])
  @@index([categoryId])
  @@index([defaultSupplierId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 38: BARCODE / LOOSE BILLING
// ─────────────────────────────────────────────────────────────────────────────
model LabelPrintLog {
  id                        String   @id @default(cuid())
  productId                 String
  barcode                   String
  weightGrams               Float
  pricePerWeightUnitAtPrint Float
  weightUnitAtPrint         String
  printedAt                 DateTime @default(now())
  printedBy                 String?

  product Product @relation(fields: [productId], references: [id])

  @@index([barcode])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 54G: RENTAL BUSINESS VERTICAL
// Availability is always computed live from active RentalBooking rows, never
// from a physical Inventory.quantity decrement — see
// PHASE_54G_RENTAL_TECHNICAL_SPEC.md Section 2.2 for why (a reservation must
// block availability before checkout, which a decrement-at-checkout-only
// model would miss). OVERDUE is likewise never a stored status — it's
// derived (status == CHECKED_OUT && endDateTime < now) wherever displayed,
// same "reclassify at display time" rule this bundle's F.9 report established.
// ─────────────────────────────────────────────────────────────────────────────

model RentalUnit {
  id                      String    @id @default(cuid())
  productId               String
  unitLabel               String // e.g. "KA01AB1234", "Console #3", "Villa - Sea View"
  status                  String    @default("AVAILABLE") // AVAILABLE | RENTED | MAINTENANCE | RETIRED
  conditionNotes          String?
  purchaseDate            DateTime?
  unitCost                Float     @default(0)
  // Phase 58 §2 — maintenance schedule tied to rental count or elapsed time.
  // Either threshold left null means that dimension is never checked for
  // this unit. Checked at returnBooking() time: a unit due for service is
  // routed to MAINTENANCE instead of AVAILABLE, blocking re-rental via the
  // exact same status check computeAvailability() already uses — no changes
  // needed to availability logic itself.
  serviceIntervalRentals  Int?
  serviceIntervalDays     Int?
  rentalCountSinceService Int       @default(0)
  lastServicedAt          DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  product      Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  bookingItems RentalBookingItem[]

  @@index([productId])
  @@index([status])
}

model RentalBooking {
  id                       String    @id @default(cuid())
  bookingNumber            String    @unique
  customerId               String
  status                   String    @default("RESERVED") // RESERVED | CHECKED_OUT | RETURNED | CANCELLED
  startDateTime            DateTime
  endDateTime              DateTime
  securityDepositCollected Float     @default(0)
  securityDepositRefunded  Float?
  lateFeeAmount            Float     @default(0)
  damageChargeAmount       Float     @default(0) // legacy aggregate — see RentalBookingItem.damageChargeAmount for the itemized amount this now sums from when item-level charges are used
  checkoutNotes            String?
  returnNotes              String?
  checkedOutAt             DateTime?
  returnedAt               DateTime?
  cancelledAt              DateTime?
  invoiceId                String? // Not a Prisma-enforced FK, deliberately — generateRentalInvoice's
  // atomic claim-sentinel (a placeholder string written here before the
  // real Invoice exists) would violate a real foreign key. Same
  // unenforced-invoiceId convention DrivingSession/DrivingPackageEnrollment
  // already use for the identical claim-then-generate-then-link pattern.
  notes                    String?
  createdById              String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  // Phase 58 §2 — recurring/standing rentals. Matches this codebase's
  // established manual-trigger recurrence pattern (see
  // ServiceRetainerAgreement/PestServiceContract's lastInvoicedPeriod claim
  // key) rather than a background scheduler, since no cron/timer infra for
  // business logic exists anywhere in this app — a staff member clicks
  // "Create Next Cycle", which is blocked from double-firing by the claim
  // flag below, exactly like every other recurring feature here.
  recurrenceIntervalDays   Int?
  parentBookingId          String?
  nextCycleGenerated       Boolean   @default(false)

  customer      Customer            @relation(fields: [customerId], references: [id])
  items         RentalBookingItem[]
  parentBooking RentalBooking?      @relation("RentalBookingRecurrence", fields: [parentBookingId], references: [id], onDelete: SetNull)
  childCycles   RentalBooking[]     @relation("RentalBookingRecurrence")

  @@index([customerId])
  @@index([status])
  @@index([startDateTime, endDateTime])
  @@index([parentBookingId])
}

model RentalBookingItem {
  id                 String   @id @default(cuid())
  bookingId          String
  productId          String
  rentalUnitId       String? // set only for UNIT-tracked items
  quantity           Float    @default(1) // used for BULK items; always 1 for UNIT items
  rateBasis          String // HOUR | DAY | WEEK | MONTH | YEAR — snapshot at booking time
  rateAmount         Float // snapshot at booking time
  lineTotal          Float // rateAmount x duration-in-rateBasis-units x quantity
  conditionOut       String?
  conditionIn        String?
  // Phase 58 §2 — itemized damage charge, attributable to this specific
  // unit on a multi-unit booking. RentalBooking.damageChargeAmount becomes
  // the sum of these when any item on the booking has one set; kept as a
  // manual fallback for a BULK item (no single physical unit to attribute
  // damage to) or a pre-existing booking created before this field existed.
  damageChargeAmount Float    @default(0)
  createdAt          DateTime @default(now())

  booking    RentalBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  product    Product       @relation(fields: [productId], references: [id])
  rentalUnit RentalUnit?   @relation(fields: [rentalUnitId], references: [id])

  @@index([bookingId])
  @@index([productId])
  @@index([rentalUnitId])
}

// ─────────────────────────────────────────────────────────────────────────────
// HOTEL / LODGE — deliberately its own vertical, not an extension of Rental.
// Rental's own header comment scopes it to short-term equipment/tool
// checkout, not overnight guest lodging — a hotel booking needs guest ID
// compliance (many jurisdictions legally require a hotel to maintain a
// guest register with ID details producible for police/immigration
// verification), per-night billing (not flexible HOUR/WEEK/MONTH rate
// bases), and in-stay extra charges (room service, laundry) that Rental
// has no equivalent of.
// ─────────────────────────────────────────────────────────────────────────────
model HotelRoom {
  id           String   @id @default(cuid())
  roomNumber   String   @unique
  roomType     String // business-defined free text, e.g. "Single", "Double", "Deluxe", "Suite"
  floor        String?
  maxOccupancy Int      @default(2)
  baseRate     Float    @default(0) // per night
  // Phase 58 §2 — flat day-use (few-daytime-hours, not overnight) rate for
  // this room. Null falls back to half of baseRate at booking time — see
  // hotel.service.ts's createBooking DAY_USE branch.
  dayUseRate   Float?
  status       String   @default("AVAILABLE") // AVAILABLE | OCCUPIED | CLEANING | MAINTENANCE | OUT_OF_ORDER
  amenities    String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings          HotelBooking[]
  housekeepingTasks HotelHousekeepingTask[]

  @@index([status])
}

// Phase 58 §2 — seasonal/date-range pricing. A blank roomType ("") is a
// blanket tier applying to every room type; a specific roomType overrides
// the blanket tier for that type on a matching date. Consulted per-night by
// hotel.service.ts's resolveNightlyRate (not a single flat lookup) so a
// booking spanning a season boundary is priced correctly night-by-night.
model HotelRateCalendar {
  id          String   @id @default(cuid())
  roomType    String   @default("") // "" = all room types; non-empty = this room type only
  startDate   DateTime
  endDate     DateTime
  rate        Float
  label       String? // e.g. "Diwali Season", "Summer Peak"
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([roomType])
  @@index([startDate, endDate])
}

// Phase 58 §2 — a real per-task housekeeping queue, replacing the bare
// room-status dropdown as the only signal of cleaning progress. Mirrors
// ProjectTask's shape (the closest existing structural cousin in this
// schema) rather than reusing it directly, since ProjectTask is hard-scoped
// to Project.
model HotelHousekeepingTask {
  id           String    @id @default(cuid())
  roomId       String
  bookingId    String? // the checkout that triggered this task, if any
  taskLabel    String // business-defined free text, e.g. "Strip beds", "Deep clean bathroom"
  status       String    @default("PENDING") // PENDING | IN_PROGRESS | DONE
  assignedToId String?
  completedAt  DateTime?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  room       HotelRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  booking    HotelBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  assignedTo Employee?     @relation("HotelHousekeepingAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([roomId])
  @@index([status])
  @@index([assignedToId])
}

model HotelBooking {
  id                   String    @id @default(cuid())
  bookingNumber        String    @unique
  roomId               String
  customerId           String?
  guestName            String
  guestPhone           String?
  guestEmail           String?
  numberOfGuests       Int       @default(1)
  checkInDate          DateTime // planned check-in (date-level; the actual moment is actualCheckInAt)
  checkOutDate         DateTime // planned check-out
  actualCheckInAt      DateTime?
  actualCheckOutAt     DateTime?
  ratePerNight         Float // average nightly rate for display/back-compat — see roomChargeTotal for the authoritative amount
  // Phase 58 §2 — the real computed room charge: a per-night calendar-resolved
  // sum for OVERNIGHT bookings that hit a HotelRateCalendar entry, or the
  // flat day-use rate for a DAY_USE booking. Null means "no calendar entry
  // matched and no override was given" — legacy behavior, roomCharge falls
  // back to ratePerNight * nights (see hotel.service.ts's serializeBooking).
  roomChargeTotal      Float?
  status               String    @default("CONFIRMED") // CONFIRMED | CHECKED_IN | CHECKED_OUT | CANCELLED | NO_SHOW
  // Phase 58 §2 — OTA/channel tagging, same free-text-with-comment convention
  // as Lead.source/Candidate.source (not a hard enum — the valid channel set
  // is business-defined, e.g. a boutique lodge may add a channel this list
  // doesn't anticipate).
  channel              String    @default("WALK_IN") // WALK_IN | BOOKING_COM | MAKEMYTRIP | AGODA | EXPEDIA | OTHER
  // Phase 58 §2 — day-use (few daytime hours) vs a normal overnight stay.
  // A DAY_USE booking still reserves the room for the full calendar day (see
  // createBooking) — a genuinely time-of-day-aware conflict check is out of
  // scope; this is the same conservative "blocks the whole day" choice a
  // real front desk already makes to give housekeeping a turnover window.
  bookingType          String    @default("OVERNIGHT") // OVERNIGHT | DAY_USE
  advanceAmount        Float     @default(0)
  advancePaymentMethod String    @default("CASH") // CASH | UPI | CARD | WALLET — recorded as a real Payment against the invoice generated at checkout
  cancelReason         String?
  notes                String?
  invoiceId            String? // unenforced FK, deliberately — same atomic claim-sentinel
  // convention RentalBooking.invoiceId documents: a placeholder string is
  // written here before the real Invoice exists, which a real foreign key
  // would reject. Also deliberately NOT @unique — a group booking's
  // generateGroupInvoice writes the same invoiceId onto multiple rows.
  createdById          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  room              HotelRoom               @relation(fields: [roomId], references: [id])
  customer          Customer?               @relation(fields: [customerId], references: [id])
  guests            HotelGuestId[]
  charges           HotelExtraCharge[]
  housekeepingTasks HotelHousekeepingTask[]

  @@index([roomId])
  @@index([status])
  @@index([checkInDate, checkOutDate])
  @@index([customerId])
}

// One row per guest occupying the room, captured at check-in — the legal
// guest-register requirement this vertical exists to support. idType's
// valid options are country-dependent (Aadhaar/Passport/Driving
// License/Voter ID/PAN in India; Passport/National ID/Driving License/Other
// elsewhere) — enforced in the validation layer against the business's own
// BusinessProfile.country, not hardcoded here as a fixed enum, since a
// SQLite String column can't itself encode "valid values depend on another
// table's row."
model HotelGuestId {
  id          String   @id @default(cuid())
  bookingId   String
  guestName   String
  idType      String
  idNumber    String
  nationality String   @default("IN")
  address     String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  booking HotelBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

// Mini-bar, room service, laundry, extra bed, etc. — billed into the guest
// folio at checkout alongside the room charge, same as a real hotel PMS.
model HotelExtraCharge {
  id          String   @id @default(cuid())
  bookingId   String
  description String
  quantity    Float    @default(1)
  unitPrice   Float
  amount      Float
  chargeDate  DateTime @default(now())
  createdById String?
  createdAt   DateTime @default(now())

  booking HotelBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY
// ─────────────────────────────────────────────────────────────────────────────
model Inventory {
  id               String   @id @default(cuid())
  productId        String   @unique
  quantity         Float    @default(0)
  reservedQuantity Float    @default(0)
  reorderLevel     Float    @default(0)
  reorderQuantity  Float    @default(0)
  averageCost      Float    @default(0)
  updatedAt        DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id])
}

model InventoryMovement {
  id            String   @id @default(cuid())
  productId     String
  movementType  String
  quantity      Float
  referenceType String?
  referenceId   String?
  remarks       String?
  createdById   String?
  createdAt     DateTime @default(now())

  product   Product @relation(fields: [productId], references: [id])
  createdBy User?   @relation("MovementCreatedBy", fields: [createdById], references: [id])

  @@index([productId])
  @@index([movementType])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMERS
// ─────────────────────────────────────────────────────────────────────────────
model Customer {
  id                 String    @id @default(cuid())
  customerCode       String?   @unique
  customerName       String
  phone              String?
  email              String?
  address            String?
  city               String?
  state              String?
  country            String?
  taxNumber          String?
  taxExempt          Boolean   @default(false) // Fresh-audit fix (2026-07-12): B2B reverse-charge / diplomatic / NGO exemption etc. — a real gap for international VAT/GST use, no way to zero tax on a customer's invoices before this
  taxExemptReason    String? // e.g. "Reverse charge — VAT Reg GB123456789" — printed on the invoice so it's not just a silent internal flag
  creditLimit        Float     @default(0)
  outstandingBalance Float     @default(0)
  notes              String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  // Phase 58 §2 — Distributor customer-class/negotiated pricing. Free text
  // (e.g. "RETAILER"/"WHOLESALER"/"VIP"), not a Prisma enum — matches this
  // schema's existing convention of validating category-style fields via a
  // Zod .enum() at the validation layer rather than a DB-level enum.
  customerClass      String?
  // Phase 58 §2 — CA Firm/Company Secretary. Most recently held/known AGM
  // date for a company client — feeds AGM-relative ROC event generation
  // (MGT-7/AOC-4/ADT-1 due 60/30/15 days after this date). Only ever set for
  // company clients; its mere presence (not a separate customerType flag,
  // which doesn't exist in this schema) is what gates AGM-relative
  // auto-generation for a given client.
  lastAgmDate        DateTime?

  documentChecklistItems    ClientDocumentChecklistItem[] // Phase 58 §2 — CA Firm
  ledgerEntries             CustomerLedger[]
  invoices                  Invoice[]
  payments                  Payment[]
  dispatchRecords           DispatchRecord[]
  metalExchanges            MetalExchange[]
  projects                  Project[]
  serviceTickets            ServiceTicket[]
  jobCards                  JobCard[]
  quotations                Quotation[]
  creditNotes               CreditNote[]
  appointments              Appointment[]
  pets                      Pet[]
  toothRecords              ToothRecord[] // Phase 25 — Dental
  treatmentPlans            TreatmentPlan[] // Phase 25 — Dental
  recallRecord              RecallRecord? // Phase 25 — Dental
  treatmentPhases           TreatmentPhase[] // Phase 26 — Physio
  exercisePrograms          ExerciseProgram[] // Phase 26 — Physio
  sessionPacks              ClientSessionPack[] // Phase 26 — Physio
  memberships               Membership[] // Phase 27 — Gym
  memberAttendances         MemberAttendance[] // Phase 27 — Gym
  batchClassAttendances     BatchClassAttendance[] // Phase 27 — Gym
  learnerProfile            LearnerProfile? // Phase 27 — Driving
  drivingSessions           DrivingSession[]              @relation("DrivingLearner") // Phase 27 — Driving
  drivingTests              DrivingTest[] // Phase 27 — Driving
  drivingPackageEnrollments DrivingPackageEnrollment[]    @relation("DrivingPackageLearner") // Phase 41 — Driving package invoicing
  legalCases                LegalCase[] // Phase 28 — Legal
  complianceTasks           ComplianceTask[] // Phase 29 — CA/CS
  engagements               Engagement[] // Phase 29 — CA
  rocFilings                ROCFiling[] // Phase 29 — CS
  boardMeetings             BoardMeeting[] // Phase 29 — CS
  serviceProjects           ServiceProject[] // Phase 30 — Arch/Civil/Consultant/Agency
  retainerAgreements        RetainerAgreement[] // Phase 30 — Consultant/Agency
  studentProfile            StudentProfile? // Phase 31 — Coaching
  coachingEnrollments       CoachingBatchEnrollment[] // Phase 31 — Coaching
  shootBookings             ShootBooking[] // Phase 32 — Photography
  eventBookings             EventBooking[] // Phase 32 — Event
  ownedProperties           Property[]                    @relation("PropertyOwner") // Phase 32 — Real Estate
  propertyInquiries         PropertyInquiry[]             @relation("InquiryBuyer") // Phase 32 — Real Estate
  dealsBuying               PropertyDeal[]                @relation("DealBuyer") // Phase 32 — Real Estate
  dealsSelling              PropertyDeal[]                @relation("DealSeller") // Phase 32 — Real Estate
  carJobCards               CarJobCard[] // Phase 33 — Car Service
  measurementRecords        MeasurementRecord[] // Phase 33 — Tailor
  tailoringOrders           TailoringOrder[] // Phase 33 — Tailor
  pestContracts             PestServiceContract[] // Phase 33 — Pest Control
  pestJobSheets             PestJobSheet[] // Phase 33 — Pest Control
  jobOrders                 JobOrder[]                    @relation("JobOrderClient") // Phase 34 — Placement
  placements                Placement[]                   @relation("PlacementClient") // Phase 34 — Placement
  labTestOrders             LabTestOrder[] // Phase 50 — Diagnostic Labs
  bloodIssues               BloodIssue[] // Phase 51 — Blood Bank
  rentalBookings            RentalBooking[] // Phase 54G — Rental
  hotelBookings             HotelBooking[] // Hotel/Lodge vertical
  heldSales                 HeldSale[] // Phase 58 §2 — Retail hold/park-sale
  shipmentStops             ShipmentStop[] // Phase 58 §2 — Distributor route/beat planning
  fieldOrderRequests        FieldOrderRequest[] // Phase 58 §2 — Distributor field-rep order capture
  repairTickets             RepairTicket[] // Phase 58 §2 — Electronics repair/RMA

  @@index([customerName])
  @@index([phone])
  @@index([isActive])
}

model CustomerLedger {
  id            String   @id @default(cuid())
  customerId    String
  referenceType String
  referenceId   String?
  debitAmount   Float    @default(0)
  creditAmount  Float    @default(0)
  balance       Float    @default(0)
  remarks       String?
  createdAt     DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// SUPPLIERS
// ─────────────────────────────────────────────────────────────────────────────
model Supplier {
  id           String   @id @default(cuid())
  supplierCode String?  @unique
  supplierName String
  phone        String?
  email        String?
  address      String?
  city         String?
  state        String?
  country      String?
  taxNumber    String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ledgerEntries         SupplierLedger[]
  purchaseOrders        PurchaseOrder[]
  batches               ProductBatch[]
  rawMaterials          RawMaterial[]
  debitNotes            DebitNote[]
  eventVendorBookings   EventVendorBooking[] // Phase 32 — Event
  defaultForProducts    Product[]            @relation("ProductDefaultSupplier") // Phase 58 §2 — reorder automation
  repairTicketsAsVendor RepairTicket[] // Phase 58 §2 — Electronics repair/RMA (vendor RMA tracking)
  rawMaterialBatches    RawMaterialBatch[] // Phase 58 §2 — Manufacturing raw-material lot traceability
}

model SupplierLedger {
  id            String   @id @default(cuid())
  supplierId    String
  referenceType String
  referenceId   String?
  debitAmount   Float    @default(0)
  creditAmount  Float    @default(0)
  balance       Float    @default(0)
  remarks       String?
  createdAt     DateTime @default(now())

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PURCHASE ORDERS
// ─────────────────────────────────────────────────────────────────────────────
model PurchaseOrder {
  id           String    @id @default(cuid())
  poNumber     String    @unique
  supplierId   String
  orderDate    DateTime  @default(now())
  expectedDate DateTime?
  status       String    @default("DRAFT")
  subtotal     Float     @default(0)
  taxAmount    Float     @default(0)
  totalAmount  Float     @default(0)
  notes        String?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  items      PurchaseOrderItem[]
  debitNotes DebitNote[]
  grns       GoodsReceiptNote[]  @relation("GRNPurchaseOrder")
}

model PurchaseOrderItem {
  id              String   @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Float
  unitCost        Float
  taxRate         Float    @default(0)
  taxAmount       Float    @default(0)
  itcAmount       Float    @default(0)
  total           Float
  createdAt       DateTime @default(now())

  receivedQty Float @default(0) // updated by postGRN() transaction — Phase 37

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICES & BILLING
// ─────────────────────────────────────────────────────────────────────────────
model Invoice {
  id                String    @id @default(cuid())
  invoiceNumber     String    @unique
  invoiceType       String    @default("RETAIL")
  customerId        String?
  invoiceDate       DateTime  @default(now())
  dueDate           DateTime?
  status            String    @default("ACTIVE")
  subtotal          Float     @default(0)
  discountAmount    Float     @default(0)
  taxAmount         Float     @default(0)
  roundingAmount    Float     @default(0)
  totalAmount       Float     @default(0)
  paidAmount        Float     @default(0)
  balanceAmount     Float     @default(0)
  paymentStatus     String    @default("UNPAID")
  gstType           String    @default("CGST_SGST")
  buyerState        String?
  notes             String?
  quotationId       String?   @unique
  originalInvoiceId String? // Set only on invoiceType='RETURN' rows — real FK to the invoice being returned against, replacing the old notes-substring-match lookup
  // Phase 58 §2 (2026-07-21) — restaurant table↔order binding. Snapshot of
  // the primary dine-in table this invoice was opened for (nullable — only
  // ever set for restaurant dine-in invoices). The reverse/live pointer
  // ("which invoice is this table currently running?") lives on
  // RestaurantTable.currentInvoiceId instead, since a merge lets MULTIPLE
  // tables point at the same invoice — a single scalar here can only ever
  // record the one table the order was opened at.
  tableId           String?
  // Set only on a new invoice produced by splitInvoice() — real FK back to
  // the original (now status='SPLIT') invoice it was divided from, mirroring
  // originalInvoiceId's return-lineage pattern above.
  splitFromInvoiceId String?
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  customer         Customer?         @relation(fields: [customerId], references: [id])
  createdBy        User?             @relation("InvoiceCreatedBy", fields: [createdById], references: [id])
  items            InvoiceItem[]
  payments         Payment[]
  kot              KOT?
  creditNotes      CreditNote[]
  quotation        Quotation?        @relation("QuotationToInvoice", fields: [quotationId], references: [id])
  challans         DeliveryChallan[] @relation("ChallanInvoice")
  originalInvoice  Invoice?          @relation("InvoiceReturns", fields: [originalInvoiceId], references: [id])
  returns          Invoice[]         @relation("InvoiceReturns")
  table            RestaurantTable?  @relation("InvoiceTable", fields: [tableId], references: [id], onDelete: SetNull)
  occupiedTables   RestaurantTable[] @relation("TableCurrentInvoice")
  splitFromInvoice Invoice?          @relation("InvoiceSplitLineage", fields: [splitFromInvoiceId], references: [id])
  splitInvoices    Invoice[]         @relation("InvoiceSplitLineage")

  @@index([customerId])
  @@index([invoiceDate])
  @@index([paymentStatus])
  @@index([status])
  @@index([status, invoiceDate])
  @@index([createdAt])
  @@index([createdById])
  @@index([originalInvoiceId])
  @@index([tableId])
  @@index([splitFromInvoiceId])
}

model InvoiceItem {
  id                      String    @id @default(cuid())
  invoiceId               String
  productId               String
  productName             String    @default("")
  productSku              String?
  hsnCode                 String?
  quantity                Float
  unitPrice               Float
  discountAmount          Float     @default(0)
  taxRate                 Float     @default(0)
  taxAmount               Float     @default(0)
  lineTotal               Float
  variantId               String?
  variantInfo             String?
  weightUnit              String?
  // Fresh-audit fix (2026-07-12): snapshot of the purity/weight/making-charge
  // breakdown a jewellery line was actually priced from — previously this was
  // computed correctly at billing time then silently discarded, so a printed
  // jewellery invoice could never show it and it was unrecoverable after the
  // sale. Null/absent for a non-jewellery line.
  jewelleryMetalType      String?
  jewelleryPurity         String?
  jewelleryNetWeight      Float?
  jewelleryRatePerGram    Float?
  jewelleryMakingCharge   Float?
  // Phase 58 §2 — hallmark/HUID number (BIS HUID in India, or equivalent),
  // snapshotted from Product.hallmarkNumber at sale time — same reasoning as
  // the jewellery fields above: a printed invoice needs the exact mark the
  // piece carried at sale, not a later-edited product record. Null/absent
  // for a non-jewellery line or a piece with no recorded hallmark.
  jewelleryHallmarkNumber String?
  // Phase 58 §2 — Pharmacy Schedule H/H1 prescription capture, same
  // "snapshot at sale time, discarded otherwise" reasoning as the jewellery
  // fields above. Null/absent for a non-prescription line.
  prescriptionPatientName String?
  prescriptionDoctorName  String?
  prescriptionDate        DateTime?
  createdAt               DateTime  @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────────────────────────────────────
model Payment {
  id              String   @id @default(cuid())
  invoiceId       String
  customerId      String?
  paymentMethod   String
  amount          Float
  referenceNumber String?
  paymentDate     DateTime @default(now())
  remarks         String?
  isReversed      Boolean  @default(false)
  reversalReason  String?
  recordedById    String?
  createdAt       DateTime @default(now())

  invoice    Invoice   @relation(fields: [invoiceId], references: [id])
  customer   Customer? @relation(fields: [customerId], references: [id])
  recordedBy User?     @relation("PaymentRecordedBy", fields: [recordedById], references: [id])

  @@index([invoiceId])
  @@index([customerId])
  @@index([paymentDate])
  @@index([isReversed])
}

// ─────────────────────────────────────────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────────────────────────────────────────
model ExpenseCategory {
  id           String   @id @default(cuid())
  categoryName String   @unique
  description  String?
  createdAt    DateTime @default(now())

  expenses Expense[]
}

model Expense {
  id            String   @id @default(cuid())
  categoryId    String
  expenseName   String
  amount        Float
  expenseDate   DateTime @default(now())
  paymentMethod String   @default("CASH")
  remarks       String?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  createdBy     User?           @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  salaryPayment SalaryPayment?

  @@index([categoryId])
  @@index([expenseDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// TAX CONFIGURATION
// ─────────────────────────────────────────────────────────────────────────────
model TaxConfiguration {
  id        String   @id @default(cuid())
  taxName   String
  taxType   String
  rate      Float
  country   String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taxName, taxType])
}

// ─────────────────────────────────────────────────────────────────────────────
// SETTINGS
// ─────────────────────────────────────────────────────────────────────────────
model Setting {
  id           String   @id @default(cuid())
  settingKey   String   @unique
  settingValue String
  settingType  String   @default("STRING")
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())
  // Phase 54F.15 — tamper-evident hash chain. Nullable because pre-migration
  // rows never had a hash computed for them; the chain simply starts fresh
  // from the first row written after this migration ships (see
  // verifyAuditLogChain in audit.service.ts for how that boundary is handled).
  hash       String?
  prevHash   String?

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType])
  @@index([entityId])
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────────────────────────
model Notification {
  id               String   @id @default(cuid())
  notificationType String
  title            String
  message          String
  isRead           Boolean  @default(false)
  createdAt        DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// BACKUPS
// ─────────────────────────────────────────────────────────────────────────────
model Backup {
  id            String   @id @default(cuid())
  backupName    String
  backupPath    String
  backupSize    BigInt   @default(0)
  backupDate    DateTime @default(now())
  backupVersion String
  schemaVersion String?
  checksum      String?
  isValid       Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// INDUSTRY TEMPLATE SETTINGS
// ─────────────────────────────────────────────────────────────────────────────
model IndustryTemplateSetting {
  id              String   @id @default(cuid())
  businessType    String   @unique
  enabledModules  String
  dashboardLayout String?
  reportLayout    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// RESTAURANT MODULE
// ─────────────────────────────────────────────────────────────────────────────
model RestaurantTable {
  id          String   @id @default(cuid())
  tableNumber String   @unique
  tableName   String?
  status      String   @default("AVAILABLE")
  // Phase 58 §2 (2026-07-17) — waiter/staff assignment for tip pooling.
  // Nullable FK to Employee, onDelete: SetNull, mirroring the established
  // TailoringOrder.assignedToId/PestServiceContract.assignedToId pattern.
  waiterId    String?
  // Phase 58 §2 (2026-07-21) — live pointer to this table's currently
  // running dine-in order. Set when an order is opened at this table (see
  // billingService.createInvoice's optional tableIds) or when another table
  // is merged into an existing one (restaurantService.mergeTableIntoInvoice)
  // — multiple RestaurantTable rows can point at the same invoiceId, which
  // is exactly how a merge is represented (no separate join table needed).
  // Cleared back to null (and status reset to AVAILABLE) the moment that
  // invoice reaches a terminal state — see releaseTablesForInvoice in
  // restaurant.service.ts, called from payments.service.ts on full
  // settlement and from billing.service.ts on cancel/split.
  currentInvoiceId String?
  createdAt   DateTime @default(now())

  kots            KOT[]
  orderRequests   TableOrderRequest[]
  waiter          Employee?           @relation("RestaurantTableWaiter", fields: [waiterId], references: [id], onDelete: SetNull)
  currentInvoice  Invoice?            @relation("TableCurrentInvoice", fields: [currentInvoiceId], references: [id], onDelete: SetNull)
  invoicesOpened  Invoice[]           @relation("InvoiceTable")
  reservations    Reservation[]

  @@index([waiterId])
  @@index([currentInvoiceId])
}

// Phase 58 §2 (2026-07-21) — real reservation record, replacing the old
// bare "RESERVED" status string on RestaurantTable which carried zero
// metadata (no time, no party size, no contact). tableId is optional: a
// reservation can be taken without pre-assigning a specific table (common
// for a phone booking made before the floor plan is known for that slot).
model Reservation {
  id           String    @id @default(cuid())
  customerName String
  phone        String
  partySize    Int
  reservedFor  DateTime
  tableId      String?
  notes        String?
  status       String    @default("CONFIRMED") // CONFIRMED | SEATED | CANCELLED | NO_SHOW
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  table RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([reservedFor])
  @@index([status])
  @@index([tableId])
}

// Phase 47 — a customer's QR-scanned order. Never becomes an Invoice/KOT on
// its own — staff must explicitly accept it (see restaurant-order.service.ts),
// so a submission here can never bill or affect inventory unattended.
model TableOrderRequest {
  id         String    @id @default(cuid())
  tableId    String
  status     String    @default("PENDING") // PENDING | ACCEPTED | REJECTED
  notes      String?
  invoiceId  String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  table RestaurantTable         @relation(fields: [tableId], references: [id])
  items TableOrderRequestItem[]

  @@index([tableId])
  @@index([status])
}

model TableOrderRequestItem {
  id        String @id @default(cuid())
  requestId String
  productId String
  quantity  Int

  request TableOrderRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

// Phase 58 §2 — Distributor customer-class / negotiated price list. A
// price here is looked up by (productId, customerClass) — resolved fresh
// server-side at every add-to-cart/accept site (see resolveCustomerPrice
// in product.service.ts), never trusted from the client, exactly like
// Product.sellingPrice itself.
model CustomerClassPrice {
  id            String   @id @default(cuid())
  productId     String
  customerClass String
  price         Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, customerClass])
  @@index([productId])
}

// Phase 58 §2 — Distributor field-rep order capture. Structural mirror of
// TableOrderRequest/TableOrderRequestItem: captures only productId+quantity
// (no price, no financial check) from a rep away from the billing counter;
// price is re-resolved fresh server-side and the credit-limit check happens
// exactly once, inside the normal billingService.createInvoice path, at
// accept time — never duplicated at capture time.
model FieldOrderRequest {
  id           String    @id @default(cuid())
  repName      String
  customerId   String?
  customerName String?
  status       String    @default("PENDING") // PENDING | ACCEPTED | REJECTED
  notes        String?
  invoiceId    String?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?

  customer Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    FieldOrderRequestItem[]

  @@index([customerId])
  @@index([status])
}

model FieldOrderRequestItem {
  id        String @id @default(cuid())
  requestId String
  productId String
  quantity  Int

  request FieldOrderRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model KOT {
  id        String   @id @default(cuid())
  invoiceId String   @unique
  tableId   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice          @relation(fields: [invoiceId], references: [id])
  table   RestaurantTable? @relation(fields: [tableId], references: [id])
}

model Recipe {
  id         String   @id @default(cuid())
  productId  String   @unique
  recipeName String
  createdAt  DateTime @default(now())

  items RecipeItem[]
}

model RecipeItem {
  id                  String   @id @default(cuid())
  recipeId            String
  ingredientProductId String
  quantity            Float
  createdAt           DateTime @default(now())

  recipe     Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Product @relation(fields: [ingredientProductId], references: [id])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 2 — INDUSTRY EXPANSION
// ─────────────────────────────────────────────────────────────────────────────

// Clothing / Footwear — Size × Colour variants per product
model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  size            String?
  color           String?
  sku             String?  @unique
  barcode         String?  @unique
  // Phase 58 §2 — Clothing/Footwear variant-aware barcode generation. Same
  // "GENERATED vs. possibly-legacy-manual" distinction as Product.barcodeSource
  // — a shop migrating existing SKUs could plausibly type in a "20…"-prefixed
  // legacy code, and folding that into the shared generated-code counter
  // (see barcode.service.ts) would corrupt the numbering.
  barcodeSource   String?
  additionalPrice Float    @default(0)
  stockQty        Float    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isActive])
}

// Pharmacy — Batch tracking with expiry dates
model ProductBatch {
  id                String    @id @default(cuid())
  productId         String
  batchNumber       String
  mfgDate           DateTime?
  expiryDate        DateTime
  quantityReceived  Float     @default(0)
  quantityRemaining Float     @default(0)
  unitCost          Float     @default(0)
  supplierId        String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  donationRecord DonationRecord? // Phase 51 — Blood Bank: this batch IS a specific collected unit

  @@unique([productId, batchNumber])
  @@index([productId])
  @@index([expiryDate])
  @@index([isActive])
}

// Electronics / Mobile — Serial number and IMEI tracking
model ProductSerial {
  id                 String    @id @default(cuid())
  productId          String
  serialNumber       String    @unique
  imeiNumber         String?   @unique
  imei2Number        String?   @unique
  warrantyMonths     Int?
  warrantyExpiryDate DateTime?
  purchaseDate       DateTime?
  unitCost           Float     @default(0)
  status             String    @default("AVAILABLE")
  invoiceId          String?
  soldDate           DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  product                   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  repairTicketsAsOriginal   RepairTicket[] @relation("RepairTicketOriginalSerial") // Phase 58 §2 — Electronics repair/RMA
  repairTicketAsReplacement RepairTicket?  @relation("RepairTicketReplacementSerial") // Phase 58 §2 — Electronics repair/RMA

  @@index([productId])
  @@index([status])
  @@index([imeiNumber])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 58 §2 — ELECTRONICS REPAIR / RMA
// ─────────────────────────────────────────────────────────────────────────────
// A post-sale service ticket linked to a specific already-sold ProductSerial/
// IMEI — distinct from JobCard (Phase 4's generic service work order, no
// serial linkage) and CarJobCard (vehicle-specific). Tracks the unit's whole
// repair lifecycle: intake, optional vendor RMA (sent out for manufacturer-
// side repair), and optional unit replacement — reusing ProductSerial.status
// (AVAILABLE/SOLD/RETURNED/DEFECTIVE) rather than inventing a parallel status
// enum, so billing/serial-picker screens don't need to learn new vocabulary.
model RepairTicket {
  id                  String    @id @default(cuid())
  claimNumber         String    @unique
  serialId            String
  productId           String
  customerId          String?
  issueDescription    String
  // RECEIVED → DIAGNOSED → SENT_TO_VENDOR → AWAITING_PARTS → REPAIRED →
  // RETURNED_TO_CUSTOMER (or → REPLACED → RETURNED_TO_CUSTOMER). CANCELLED is
  // reachable only before REPAIRED/REPLACED — see repair-ticket.service.ts's
  // ALLOWED_TRANSITIONS.
  status              String    @default("RECEIVED")
  receivedDate        DateTime  @default(now())
  deliveredDate       DateTime?
  vendorId            String?
  vendorRmaNumber     String?
  sentToVendorDate    DateTime?
  vendorResponseDate  DateTime?
  // Set only when status becomes REPLACED — the NEW physical unit (must be an
  // AVAILABLE serial of the SAME product) handed to the customer in place of
  // the original. @unique so one replacement unit can never be assigned to
  // two different tickets.
  replacementSerialId String?   @unique
  repairCost          Float?
  notes               String?
  createdById         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  serial            ProductSerial  @relation("RepairTicketOriginalSerial", fields: [serialId], references: [id])
  product           Product        @relation(fields: [productId], references: [id])
  customer          Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  vendor            Supplier?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  replacementSerial ProductSerial? @relation("RepairTicketReplacementSerial", fields: [replacementSerialId], references: [id], onDelete: SetNull)

  @@index([serialId])
  @@index([status])
  @@index([customerId])
  @@index([productId])
}

// ─────────────────────────────────────────────────────────────────────────────
// DAILY CASH CLOSE
// ─────────────────────────────────────────────────────────────────────────────
model DailyCashClose {
  id           String   @id @default(cuid())
  closeDate    DateTime
  expectedCash Float
  actualCash   Float
  variance     Float
  notes        String?
  closedById   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([closeDate])
  @@index([closeDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 3 — MANUFACTURING LITE
// ─────────────────────────────────────────────────────────────────────────────

model RawMaterial {
  id           String   @id @default(cuid())
  name         String
  unit         String   @default("kg")
  currentStock Float    @default(0)
  reorderLevel Float    @default(0)
  unitCost     Float    @default(0)
  supplierId   String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier        Supplier?                 @relation(fields: [supplierId], references: [id])
  movements       RawMaterialMovement[]
  bomItems        BillOfMaterialItem[]
  productionUsage ProductionMaterialUsage[]
  batches         RawMaterialBatch[] // Phase 58 §2 — lot/batch traceability

  @@index([isActive])
  @@index([supplierId])
}

model RawMaterialMovement {
  id            String   @id @default(cuid())
  rawMaterialId String
  type          String // PURCHASE, CONSUMED, ADJUSTMENT, RETURN
  quantity      Float
  balanceAfter  Float    @default(0)
  reference     String?
  unitCost      Float    @default(0)
  notes         String?
  createdById   String?
  createdAt     DateTime @default(now())

  rawMaterial RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@index([rawMaterialId])
  @@index([type])
  @@index([createdAt])
}

model BillOfMaterial {
  id          String   @id @default(cuid())
  productId   String   @unique
  description String?
  outputQty   Float    @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product          Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  items            BillOfMaterialItem[]
  productionOrders ProductionOrder[]

  @@index([isActive])
}

model BillOfMaterialItem {
  id                 String  @id @default(cuid())
  bomId              String
  // Phase 58 §2 — multi-level BOM: a line is EITHER a raw material OR
  // another finished/semi-finished Product with its own BOM (a
  // sub-assembly), never both — enforced in bom.service.ts, not at the DB
  // level (SQLite has no portable CHECK-constraint-on-two-columns story in
  // this project's migration workflow). rawMaterialId is now nullable to
  // make room for componentProductId; existing single-level BOMs are
  // unaffected (componentProductId stays null for every pre-existing row).
  rawMaterialId      String?
  componentProductId String?
  quantityNeeded     Float
  wastagePercent     Float   @default(0)

  bom              BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  rawMaterial      RawMaterial?   @relation(fields: [rawMaterialId], references: [id])
  componentProduct Product?       @relation("BomComponentProduct", fields: [componentProductId], references: [id])

  @@index([bomId])
  @@index([componentProductId])
}

model ProductionOrder {
  id            String    @id @default(cuid())
  orderNumber   String    @unique
  productId     String
  bomId         String
  plannedQty    Float
  producedQty   Float     @default(0)
  // Phase 58 §2 — units consumed material (and labor) but failed QC / were
  // rejected, distinct from a simple "produced less than planned" shortfall.
  // producedQty is GOOD units added to inventory; scrapQty is additional
  // units attempted (material+labor spent) that are NOT sellable.
  scrapQty      Float     @default(0)
  // Phase 58 §2 — folded into the produced unit's cost basis alongside
  // material cost (see completeProductionOrder), instead of every
  // manufactured good silently carrying a material-only cost that never
  // reflected the labor that went into making it.
  laborCost     Float     @default(0)
  status        String    @default("DRAFT")
  startDate     DateTime?
  completedDate DateTime?
  notes         String?
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  product       Product                   @relation(fields: [productId], references: [id])
  bom           BillOfMaterial            @relation(fields: [bomId], references: [id])
  materialUsage ProductionMaterialUsage[]
  workOrders    WorkOrder[]

  @@index([status])
  @@index([productId])
  @@index([createdAt])
}

model ProductionMaterialUsage {
  id                 String  @id @default(cuid())
  productionOrderId  String
  // Phase 58 §2 — mirrors BillOfMaterialItem: exactly one of
  // rawMaterialId/componentProductId is set, matching whichever kind of BOM
  // line this usage row was generated from.
  rawMaterialId      String?
  componentProductId String?
  quantityPlanned    Float
  quantityActual     Float   @default(0)

  productionOrder  ProductionOrder                      @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  rawMaterial      RawMaterial?                         @relation(fields: [rawMaterialId], references: [id])
  componentProduct Product?                             @relation("ProductionComponentUsage", fields: [componentProductId], references: [id])
  batchConsumption ProductionMaterialBatchConsumption[]

  @@index([productionOrderId])
}

// Phase 58 §2 — raw-material lot/batch traceability: which specific
// received lot(s) of a raw material were actually consumed by a given
// production order. A join table (not a single batchId on
// ProductionMaterialUsage) because FIFO consumption of one usage row can
// legitimately span multiple batches (e.g. 8kg needed, batch A has 5kg
// left, batch B covers the remaining 3kg) — same reasoning
// InventoryMovement/ProductBatch don't collapse a sale's FIFO draw into one
// row either.
model ProductionMaterialBatchConsumption {
  id                        String @id @default(cuid())
  productionMaterialUsageId String
  rawMaterialBatchId        String
  quantityConsumed          Float

  productionMaterialUsage ProductionMaterialUsage @relation(fields: [productionMaterialUsageId], references: [id], onDelete: Cascade)
  rawMaterialBatch        RawMaterialBatch        @relation(fields: [rawMaterialBatchId], references: [id])

  @@index([productionMaterialUsageId])
  @@index([rawMaterialBatchId])
}

// Phase 58 §2 — a received lot of raw material, mirroring ProductBatch's
// shape for finished goods. RawMaterial.currentStock remains the
// authoritative aggregate stock figure (unchanged) — this is an ADDITIONAL
// ledger for traceability, same "aggregate figure + a separate lot ledger"
// relationship ProductBatch already has with Inventory.quantity.
model RawMaterialBatch {
  id                String   @id @default(cuid())
  rawMaterialId     String
  batchNumber       String
  receivedDate      DateTime @default(now())
  quantityReceived  Float
  quantityRemaining Float
  unitCost          Float    @default(0)
  supplierId        String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())

  rawMaterial RawMaterial                          @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  supplier    Supplier?                            @relation(fields: [supplierId], references: [id])
  consumption ProductionMaterialBatchConsumption[]

  @@unique([rawMaterialId, batchNumber])
  @@index([rawMaterialId])
  @@index([isActive])
}

model WorkOrder {
  id                String    @id @default(cuid())
  productionOrderId String
  stepNumber        Int
  taskName          String
  status            String    @default("PENDING")
  // Phase 58 §2 — QC/inspection gate: a step flagged as a QC checkpoint
  // requires a pass/fail result before it can be marked DONE (enforced in
  // work-order.service.ts). Ordinary (non-QC) steps are unaffected — this is
  // additive, not a behavior change for existing production workflows.
  isQcStep          Boolean   @default(false)
  qcResult          String?
  qcNotes           String?
  notes             String?
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@unique([productionOrderId, stepNumber])
  @@index([productionOrderId])
  @@index([status])
}

model DispatchRecord {
  id                String    @id @default(cuid())
  dispatchNumber    String    @unique
  productId         String
  productionOrderId String?
  quantity          Float
  customerId        String?
  destination       String?
  status            String    @default("READY")
  dispatchDate      DateTime?
  deliveryDate      DateTime?
  notes             String?
  createdById       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  product  Product   @relation(fields: [productId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([status])
  @@index([productId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 4 — SERVICE BUSINESS MODULE
// ─────────────────────────────────────────────────────────────────────────────

model Project {
  id              String    @id @default(cuid())
  projectNumber   String    @unique
  title           String
  description     String?
  status          String    @default("OPEN")
  priority        String    @default("MEDIUM")
  customerId      String?
  assignedToId    String?
  estimatedHours  Float     @default(0)
  estimatedAmount Float     @default(0)
  startDate       DateTime?
  dueDate         DateTime?
  completedDate   DateTime?
  notes           String?
  createdById     String?
  // Phase 58 §1 (2026-07-17) — legacy Service/Consultant invoicing bridge,
  // same invoiceId-on-the-entity convention every other invoiceable model
  // in this schema already uses (CarJobCard, Placement, ShootBooking, etc.).
  invoiceId       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer   Customer?     @relation(fields: [customerId], references: [id])
  assignedTo User?         @relation("ProjectAssignedTo", fields: [assignedToId], references: [id])
  tasks      ProjectTask[]
  workLogs   WorkLog[]

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
}

model ProjectTask {
  id             String    @id @default(cuid())
  projectId      String
  title          String
  description    String?
  status         String    @default("PENDING")
  priority       String    @default("MEDIUM")
  estimatedHours Float     @default(0)
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model ServiceTicket {
  id           String    @id @default(cuid())
  ticketNumber String    @unique
  title        String
  description  String?
  status       String    @default("OPEN")
  priority     String    @default("MEDIUM")
  category     String?
  customerId   String?
  assignedToId String?
  resolvedAt   DateTime?
  closedAt     DateTime?
  resolution   String?
  createdById  String?
  invoiceId    String? // Phase 58 §1 — legacy Service/Consultant invoicing bridge
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customer   Customer? @relation(fields: [customerId], references: [id])
  assignedTo User?     @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  workLogs   WorkLog[]

  @@index([status])
  @@index([customerId])
  @@index([priority])
  @@index([createdAt])
}

model JobCard {
  id                     String    @id @default(cuid())
  jobNumber              String    @unique
  title                  String
  itemDescription        String?
  status                 String    @default("RECEIVED")
  priority               String    @default("MEDIUM")
  customerId             String?
  assignedToId           String?
  estimatedCost          Float     @default(0)
  actualCost             Float     @default(0)
  receivedDate           DateTime  @default(now())
  expectedDate           DateTime?
  deliveredDate          DateTime?
  notes                  String?
  internalNotes          String?
  createdById            String?
  invoiceId              String? // Phase 58 §1 — legacy Repair Shop invoicing bridge
  // Phase 58 §2 — Repair: a NEW warranty period covering the repair work
  // itself, distinct from any original manufacturer warranty tracked on a
  // sold SerialNumber elsewhere. warrantyDays is entered any time; the
  // concrete warrantyExpiryDate is only ever computed once deliveredDate is
  // known (deliveredDate + warrantyDays) — a job still in progress has no
  // real delivery date to count from yet.
  warrantyDays           Int?
  warrantyExpiryDate     DateTime?
  // If this job is itself a comeback under a PRIOR job's repair warranty,
  // this points at that original job — informational only (never blocks
  // creating a new job card, since a shop may still choose to accept an
  // out-of-warranty comeback as a fresh paid job).
  warrantyClaimAgainstId String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  customer             Customer?     @relation(fields: [customerId], references: [id])
  assignedTo           User?         @relation("JobCardAssignedTo", fields: [assignedToId], references: [id])
  workLogs             WorkLog[]
  parts                JobCardPart[]
  warrantyClaimAgainst JobCard?      @relation("JobCardWarrantyClaim", fields: [warrantyClaimAgainstId], references: [id], onDelete: SetNull)
  warrantyClaims       JobCard[]     @relation("JobCardWarrantyClaim")

  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@index([warrantyClaimAgainstId])
}

// Phase 58 §2 — Repair: parts actually consumed on a job card, backed by
// REAL inventory deduction (not the free-text JSON blob CarJobCard's
// partsItems uses) — unitPrice is snapshotted at time of use so a later
// price change on the Product doesn't retroactively rewrite history.
model JobCardPart {
  id        String   @id @default(cuid())
  jobCardId String
  productId String
  quantity  Float
  unitPrice Float
  createdAt DateTime @default(now())

  jobCard JobCard @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([jobCardId])
  @@index([productId])
}

model WorkLog {
  id          String   @id @default(cuid())
  projectId   String?
  ticketId    String?
  jobCardId   String?
  userId      String?
  title       String
  description String?
  hours       Float    @default(0)
  logDate     DateTime @default(now())
  billable    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user    User?          @relation(fields: [userId], references: [id])
  project Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ticket  ServiceTicket? @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  jobCard JobCard?       @relation(fields: [jobCardId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([ticketId])
  @@index([jobCardId])
  @@index([userId])
  @@index([logDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 11 — DOCUMENT MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────

model Document {
  id            String   @id @default(cuid())
  fileName      String
  storedName    String
  filePath      String
  mimeType      String   @default("application/octet-stream")
  fileSizeBytes BigInt   @default(0)
  entityType    String // INVOICE | PURCHASE_ORDER | CUSTOMER | SUPPLIER | EXPENSE | PRODUCTION_ORDER
  entityId      String
  notes         String?
  uploadedById  String?
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 17 — HR & ATTENDANCE
// ─────────────────────────────────────────────────────────────────────────────

model Employee {
  id             String    @id @default(cuid())
  employeeNumber String?   @unique
  fullName       String
  phone          String?
  email          String?
  department     String?
  designation    String?
  employeeType   String    @default("FULL_TIME") // FULL_TIME, PART_TIME, CONTRACT, DAILY_WAGE
  joinDate       DateTime
  exitDate       DateTime?
  isActive       Boolean   @default(true)
  salaryType     String    @default("MONTHLY") // MONTHLY, DAILY, HOURLY
  basicSalary    Float     @default(0)
  allowances     String    @default("[]") // JSON: [{name:string, amount:number}]
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  commissionRate          Float?
  commissionType          String? @default("PERCENT") // Phase 27 — Salon/Gym: PERCENT|FLAT
  hourlyBillingRate       Float?
  specialization          String?
  providerCalendarEnabled Boolean @default(false)
  providerColor           String?
  maxAppointmentsPerDay   Int?

  primaryLocationId String? // Phase 36 — reserved for V2 multi-location (not populated in V1)

  attendances               Attendance[]
  leaveRequests             LeaveRequest[]
  appointments              Appointment[]             @relation("AppointmentProvider")
  providerSchedules         ProviderSchedule[]
  toothRecordings           ToothRecord[]             @relation("ToothRecordRecordedBy") // Phase 25 — Dental
  toothRecordHistoryEntries ToothRecordHistory[]      @relation("ToothRecordHistoryRecordedBy") // Phase 58 §2 — Dental
  serviceSkills             ServiceProviderSkill[] // Phase 58 §2 — Beauty Salon: which services this staff member can perform
  assignedSessionPacks      ClientSessionPack[]       @relation("SessionPackAssignedTrainer") // Phase 58 §2 — Gym/Studio: PT packages this trainer is the standing assignee for
  treatmentPlansCreated     TreatmentPlan[]           @relation("TreatmentPlanCreatedBy") // Phase 25 — Dental
  treatmentPhasesCreated    TreatmentPhase[]          @relation("TreatmentPhaseCreatedBy") // Phase 26 — Physio
  exerciseProgramsCreated   ExerciseProgram[]         @relation("ExerciseProgramCreatedBy") // Phase 26 — Physio
  staffCommissions          StaffCommission[] // Phase 27 — Commission
  batchClassesInstructed    BatchClass[]              @relation("BatchClassInstructor") // Phase 27 — Gym
  drivingSessionsTaught     DrivingSession[]          @relation("DrivingSessionInstructor") // Phase 27 — Driving
  drivingVehiclesAssigned   DrivingVehicle[]          @relation("VehicleInstructor") // Phase 27 — Driving
  drivingTestsInstructed    DrivingTest[]             @relation("DrivingTestInstructor") // Phase 58 §2 — Driving
  legalCasesAsAdvocate      LegalCase[]               @relation("CaseAdvocate") // Phase 28 — Legal
  timeEntries               TimeEntry[] // Phase 28 — Legal
  complianceTasks           ComplianceTask[]          @relation("TaskStaff") // Phase 29 — CA/CS
  engagements               Engagement[]              @relation("EngagementStaff") // Phase 29 — CA
  rocFilings                ROCFiling[]               @relation("ROCFilingStaff") // Phase 29 — CS
  assignedLeads             Lead[]                    @relation("LeadAssignee") // Phase 30
  assignedServiceProjects   ServiceProject[]          @relation("ServiceProjectAssignee") // Phase 30
  retainerAgreements        RetainerAgreement[]       @relation("RetainerAssignee") // Phase 30
  assignedIssues            Issue[]                   @relation("IssueAssignee") // Phase 30
  coachingBatchesInstructed CoachingBatch[]           @relation("CoachingBatchInstructor") // Phase 31
  coachingAttendancesTaken  CoachingBatchAttendance[] @relation("CoachingAttendanceTaker") // Phase 31
  shootsEdited              ShootBooking[]            @relation("ShootEditor") // Phase 32
  carJobsAdvised            CarJobCard[]              @relation("CarJobAdvisor") // Phase 33
  measurementsTaken         MeasurementRecord[]       @relation("MeasurementTakenBy") // Phase 33
  tailoringOrdersAssigned   TailoringOrder[]          @relation("TailoringAssignedTo") // Phase 33
  pestContractsAssigned     PestServiceContract[]     @relation("PestContractAssignee") // Phase 33
  restaurantTablesWaited    RestaurantTable[]         @relation("RestaurantTableWaiter") // Phase 58 §2
  hotelHousekeepingTasks    HotelHousekeepingTask[]   @relation("HotelHousekeepingAssignee") // Phase 58 §2
  labOrdersReferred         LabTestOrder[]            @relation("LabOrderReferrer") // Phase 50
  labOrdersSampleCollected  LabTestOrder[]            @relation("LabOrderSampleCollector") // Phase 50
  labOrdersReported         LabTestOrder[]            @relation("LabOrderReporter") // Phase 50
  labItemsCriticalNotified  LabTestOrderItem[]        @relation("LabItemCriticalNotifiedBy") // Phase 58 §2
  salaryPayments            SalaryPayment[] // Phase 54F.16
  siteVisitsRecorded        SiteVisit[]               @relation("SiteVisitRecordedBy") // Fresh-audit build — Civil Engineer

  @@index([isActive])
  @@index([department])
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime
  status     String   @default("PRESENT") // PRESENT, ABSENT, HALF_DAY, LEAVE, HOLIDAY, WEEK_OFF
  checkIn    String? // "09:00"
  checkOut   String? // "18:00"
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([date])
  @@index([employeeId])
}

model LeaveType {
  id        String   @id @default(cuid())
  name      String   @unique
  maxDays   Int      @default(0) // 0 = unlimited
  isPaid    Boolean  @default(true)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  leaveRequests LeaveRequest[]
}

model LeaveRequest {
  id          String    @id @default(cuid())
  employeeId  String
  leaveTypeId String
  fromDate    DateTime
  toDate      DateTime
  days        Float
  reason      String?
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy  String?
  approvedAt  DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([status])
  @@index([fromDate])
}

// ─── Phase 54F.16: Real Payroll ──────────────────────────────────────────────
// Deliberately owner-configurable deductions (name+amount pairs), not computed
// statutory formulas — see PHASE_54F_16_TECHNICAL_SPEC.md Section 1 for why
// (PF wage ceilings / ESI thresholds / state-specific PT slabs / annual TDS
// math all change with government notifications; a wrong auto-computed number
// is a worse failure mode than an empty field the owner or their CA fills in).
model SalaryPayment {
  id              String    @id @default(cuid())
  employeeId      String
  periodYear      Int
  periodMonth     Int // 1-12
  basicSalary     Float
  allowances      String    @default("[]") // JSON snapshot: [{name, amount}] — copied from Employee at generation time
  grossSalary     Float
  deductions      String    @default("[]") // JSON: [{name, amount}] — e.g. PF, ESI, Professional Tax, TDS, Advance Recovery
  totalDeductions Float     @default(0)
  netPayable      Float
  status          String    @default("DRAFT") // DRAFT | PAID
  paidDate        DateTime?
  paymentMethod   String?
  expenseId       String?   @unique // set once marked PAID — the real Expense row this payroll run created
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
  expense  Expense? @relation(fields: [expenseId], references: [id])

  @@unique([employeeId, periodYear, periodMonth])
  @@index([periodYear, periodMonth])
  @@index([status])
}

// ─── Phase 20: Billing Feature Depth ─────────────────────────────────────────

// Phase 58 §2 — hold/park-sale on the Billing/POS screen. Deliberately NOT
// built on Quotation: a hold would otherwise burn a real customer-facing
// QT-xxxxx sequence number on every park (even ones resumed 30 seconds
// later), clutter QuotationsScreen/quotation reports with throwaway rows,
// and can't round-trip the cart's variant/serial/batch/jewellery detail or
// its currency-amount (not percentage) per-line discount. A single JSON
// blob snapshot of the cart — same precedent as Product.rentalRates — is
// the cheapest correct fit for something this ephemeral: a row existing
// means it's held, deleting it (on resume or explicit abandon) is the only
// lifecycle. No stock reservation, no notification, no sequence number.
model HeldSale {
  id          String   @id @default(cuid())
  label       String? // optional cashier note, e.g. "Rahul - blue shirt"
  customerId  String?
  cartJson    String // serialized cart snapshot: items[], customer, discount, paymentMethod, notes, referenceNumber
  itemCount   Int // denormalized for the resume-list UI, avoids parsing cartJson just to show a count
  totalAmount Float // denormalized for the resume-list UI, same reason
  createdById String?
  createdAt   DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model Quotation {
  id              String    @id @default(cuid())
  quotationNumber String    @unique
  customerId      String?
  customerName    String?
  validUntil      DateTime?
  status          String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, EXPIRED
  subtotal        Float     @default(0)
  taxAmount       Float     @default(0)
  discountAmount  Float     @default(0)
  totalAmount     Float     @default(0)
  notes           String?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    QuotationItem[]
  invoice  Invoice?        @relation("QuotationToInvoice")

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String
  productId   String?
  productName String
  sku         String?
  quantity    Float
  unitPrice   Float
  discount    Float   @default(0)
  taxRate     Float   @default(0)
  lineTotal   Float

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model CreditNote {
  id               String   @id @default(cuid())
  creditNoteNumber String   @unique
  customerId       String?
  invoiceId        String?
  reason           String
  amount           Float
  notes            String?
  createdBy        String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoice  Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([invoiceId])
  @@index([createdAt])
}

model DebitNote {
  id              String   @id @default(cuid())
  debitNoteNumber String   @unique
  supplierId      String?
  purchaseOrderId String?
  reason          String
  amount          Float
  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  supplier      Supplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@index([supplierId])
  @@index([purchaseOrderId])
  @@index([createdAt])
}

// ─── Phase 22: Service Business Foundation ───────────────────────────────────

model ServiceCatalog {
  id              String   @id @default(cuid())
  serviceName     String
  serviceCode     String?  @unique
  category        String?
  description     String?
  durationMinutes Int      @default(30)
  basePrice       Float    @default(0)
  taxRate         Float    @default(0)
  sacCode         String?
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  locationId String? // Phase 36 — reserved for V2 multi-location (not populated in V1)

  appointments      Appointment[]
  labTestOrderItems LabTestOrderItem[] // Phase 50 — Diagnostic Labs: test/panel catalog reuses this model
  providerSkills    ServiceProviderSkill[] // Phase 58 §2 — Beauty Salon: which staff can perform this service

  @@index([isActive])
  @@index([category])
  @@index([serviceName])
}

// Phase 58 §2 — Beauty Salon: stylist skill-matching, replacing any-staff-
// any-service. Deliberately an OPT-IN join table, not a required field on
// either side: a service with ZERO configured rows here means "any provider
// can perform it" (the booking form's provider picker falls back to showing
// everyone) — a business that never configures skills sees no behavior
// change at all, same additive-by-default convention as this session's
// other opt-in module flags.
model ServiceProviderSkill {
  id               String   @id @default(cuid())
  employeeId       String
  serviceCatalogId String
  createdAt        DateTime @default(now())

  employee       Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  serviceCatalog ServiceCatalog @relation(fields: [serviceCatalogId], references: [id], onDelete: Cascade)

  @@unique([employeeId, serviceCatalogId])
  @@index([employeeId])
  @@index([serviceCatalogId])
}

model Appointment {
  id                 String   @id @default(cuid())
  appointmentNumber  String   @unique
  customerId         String?
  customerName       String?
  providerId         String?
  serviceCatalogId   String?
  serviceTitle       String
  scheduledDate      DateTime
  scheduledTime      String
  durationMinutes    Int      @default(30)
  status             String   @default("SCHEDULED") // SCHEDULED|CONFIRMED|IN_PROGRESS|COMPLETED|CANCELLED|NO_SHOW
  notes              String?
  privateNotes       String?
  cancellationReason String?
  invoiceId          String?
  totalAmount        Float    @default(0)
  depositPaid        Float    @default(0)
  createdBy          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  petId                   String? // Phase 23 — Vet: link to patient
  chairAssignment         String? // Phase 25 — Dental: chair number (Chair 1, Chair 2, etc.)
  services                String? // Phase 27 — Salon: JSON [{id,serviceName,price,duration}]
  locationId              String? // Phase 36 — reserved for V2 multi-location (not populated in V1)
  referredFromVisitNoteId String? // Phase 54F — real in-app referral: this appointment was booked FROM a visit note's "refer to another provider" action, not created standalone. Distinct from VisitNote.referredBy (that's the free-text record of an inbound referral from an outside doctor); this is the outbound, in-app-routed case.

  customer              Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  provider              Employee?        @relation("AppointmentProvider", fields: [providerId], references: [id], onDelete: SetNull)
  serviceCatalog        ServiceCatalog?  @relation(fields: [serviceCatalogId], references: [id], onDelete: SetNull)
  pet                   Pet?             @relation(fields: [petId], references: [id], onDelete: SetNull)
  visitNote             VisitNote?       @relation("AppointmentOwnVisitNote") // Phase 24 — Medical: SOAP consultation note for THIS appointment
  referredFromVisitNote VisitNote?       @relation("ReferralSource", fields: [referredFromVisitNoteId], references: [id], onDelete: SetNull) // Phase 54F — the note that referred the patient TO this appointment
  tokenQueueEntry       TokenQueue? // Phase 24 — GP: token queue link
  sessionLog            SessionLog? // Phase 26 — Physio: session pack deduction
  staffCommission       StaffCommission? // Phase 27 — Salon/Gym: commission record
  labTestOrder          LabTestOrder? // Phase 50 — Diagnostic Labs: sample-collection visit link
  tailoringTrialFor     TailoringOrder? // Phase 58 §2 — Tailor Boutique: this appointment IS the order's trial/fitting visit

  @@index([customerId])
  @@index([providerId])
  @@index([scheduledDate])
  @@index([status])
  @@index([referredFromVisitNoteId])
  @@index([createdAt])
  @@index([petId])
}

// ─── Phase 50: Diagnostic & Pathology Labs ───────────────────────────────────
// Test/panel catalog deliberately reuses ServiceCatalog (a lab creates catalog
// rows like "Complete Blood Count"/"Lipid Profile"/"Chest X-Ray" with
// category="Pathology"/"Radiology"/"Panel") rather than a parallel catalog
// model. appointmentId links an order to a sample-collection visit when one
// was booked; referredByProviderId/referringNotes record a referral — either
// from a provider within this same install, or (the far more common case,
// since Sarang is single-business/offline with no cross-install networking)
// free text naming an external referring doctor/clinic.
model LabTestOrder {
  id                   String    @id @default(cuid())
  orderNumber          String    @unique
  customerId           String?
  patientName          String
  patientAge           String?
  appointmentId        String?   @unique
  referredByProviderId String?
  referringNotes       String?
  status               String    @default("ORDERED") // ORDERED|SAMPLE_COLLECTED|IN_PROCESS|REPORTED|DELIVERED|CANCELLED
  sampleCollectedAt    DateTime?
  sampleCollectedById  String?
  reportedAt           DateTime?
  reportedById         String?
  totalAmount          Float     @default(0)
  invoiceId            String?
  notes                String?
  createdBy            String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  customer           Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  appointment        Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  referredByProvider Employee?          @relation("LabOrderReferrer", fields: [referredByProviderId], references: [id], onDelete: SetNull)
  sampleCollectedBy  Employee?          @relation("LabOrderSampleCollector", fields: [sampleCollectedById], references: [id], onDelete: SetNull)
  reportedBy         Employee?          @relation("LabOrderReporter", fields: [reportedById], references: [id], onDelete: SetNull)
  items              LabTestOrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

// One row per test/panel within an order — a single visit commonly orders
// several tests (e.g. CBC + Lipid Profile + Thyroid Panel) that can each
// complete at different times, hence per-item status. resultParameters holds
// structured pathology results (JSON: [{parameter,value,unit,referenceRange,
// flag}]); resultSummary is free text for imaging/radiology-style findings
// that don't decompose into discrete parameters. testName/category/price are
// denormalized snapshots (same pattern as InvoiceItem denormalizing
// productName) so a later rename/deactivation of the catalog entry doesn't
// change historical orders.
model LabTestOrderItem {
  id                    String    @id @default(cuid())
  labTestOrderId        String
  serviceCatalogId      String?
  testName              String
  category              String?
  sampleType            String    @default("BLOOD") // BLOOD|URINE|STOOL|SWAB|IMAGING|OTHER
  price                 Float     @default(0)
  status                String    @default("PENDING") // PENDING|COLLECTED|RESULT_READY|REPORTED
  resultParameters      String    @default("[]")
  resultSummary         String?
  // Phase 58 §2 — critical/panic-value escalation. hasCriticalResult is a
  // derived, cached flag (recomputed server-side from resultParameters on
  // every save, same "derived, cached for fast querying" convention as
  // other boolean summary columns in this codebase) so a pending-escalation
  // dashboard query never has to parse the JSON blob of every item. The
  // notified fields record that the referring doctor was actually called —
  // the escalation workflow itself, not just the flag.
  hasCriticalResult     Boolean   @default(false)
  criticalNotifiedAt    DateTime?
  criticalNotifiedById  String?
  criticalNotifiedNotes String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  labTestOrder       LabTestOrder    @relation(fields: [labTestOrderId], references: [id], onDelete: Cascade)
  serviceCatalog     ServiceCatalog? @relation(fields: [serviceCatalogId], references: [id], onDelete: SetNull)
  criticalNotifiedBy Employee?       @relation("LabItemCriticalNotifiedBy", fields: [criticalNotifiedById], references: [id], onDelete: SetNull)

  @@index([labTestOrderId])
  @@index([status])
  @@index([hasCriticalResult])
}

// ─── Phase 51: Blood Bank ─────────────────────────────────────────────────────
// Donor management is structurally distinct from Customer (medical eligibility
// fields, not a billing party) so gets its own model rather than overloading
// Customer. Each collected+screened-passed unit becomes one ProductBatch row
// under a single shared "Blood Unit" placeholder Product (found-or-created,
// same pattern as findOrCreateServiceCatalogProduct/findOrCreateTestProduct in
// appointment.service.ts/lab-test-order.service.ts) — DonationRecord carries
// all the real blood-specific semantics (group/component/donor/camp) while
// ProductBatch is reused purely as the underlying stock-quantity/expiry ledger.
// This is why BLOOD_BANK does NOT get the generic batch_tracking module/screen
// (see industry-template.service.ts's comment): the generic BatchManagement
// screen's hardcoded 30-day "expiring soon" window is wrong for blood (a 5-day
// platelet shelf life would show every single platelet unit as "expiring" at
// all times) and has no blood-group grouping — Blood Bank gets its own
// dedicated stock screen with per-component-type alert thresholds instead.
model Donor {
  id                        String    @id @default(cuid())
  donorCode                 String    @unique
  fullName                  String
  phone                     String?
  email                     String?
  dateOfBirth               DateTime?
  gender                    String?
  bloodGroup                String? // A+|A-|B+|B-|AB+|AB-|O+|O-|UNKNOWN
  weightKg                  Float?
  address                   String?
  lastDonationDate          DateTime?
  // Phase 58 §2 — denormalized alongside lastDonationDate (same write site,
  // updateScreeningStatus's PASSED branch) so the donor-list eligibility
  // calculation can vary the cooldown by component type without an N+1
  // query per donor — the same reasoning every other denormalized snapshot
  // field in this codebase already documents.
  lastDonationComponentType String?
  isDeferred                Boolean   @default(false)
  deferralReason            String?
  deferredUntil             DateTime?
  notes                     String?
  isActive                  Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  donations DonationRecord[]

  @@index([bloodGroup])
  @@index([isActive])
  @@index([fullName])
}

model DonationCamp {
  id        String   @id @default(cuid())
  campName  String
  location  String?
  campDate  DateTime
  organizer String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donations DonationRecord[]

  @@index([campDate])
}

model DonationRecord {
  id              String   @id @default(cuid())
  donationNumber  String   @unique
  donorId         String
  campId          String?
  collectionDate  DateTime @default(now())
  bloodGroup      String
  componentType   String   @default("WHOLE_BLOOD") // WHOLE_BLOOD|PACKED_RBC|PLATELETS|PLASMA|CRYOPRECIPITATE
  volumeMl        Float    @default(450)
  screeningStatus String   @default("PENDING") // PENDING|PASSED|FAILED
  screeningNotes  String?
  productBatchId  String?  @unique
  isIssued        Boolean  @default(false)
  notes           String?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  donor          Donor           @relation(fields: [donorId], references: [id], onDelete: Cascade)
  camp           DonationCamp?   @relation(fields: [campId], references: [id], onDelete: SetNull)
  productBatch   ProductBatch?   @relation(fields: [productBatchId], references: [id], onDelete: SetNull)
  bloodIssueItem BloodIssueItem?

  @@index([donorId])
  @@index([bloodGroup])
  @@index([screeningStatus])
  @@index([collectionDate])
}

model BloodIssue {
  id            String   @id @default(cuid())
  issueNumber   String   @unique
  customerId    String?
  recipientName String
  purpose       String?
  status        String   @default("ISSUED") // ISSUED|CANCELLED
  totalAmount   Float    @default(0)
  invoiceId     String?
  issuedById    String?
  notes         String?
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  // Populated from the logged-in session's userId (who clicked "Issue Units"),
  // NOT a dropdown-selected staff member — so this must reference User (the
  // auth/session identity), not Employee (a separate HR-only ID space with no
  // link to User at all). Found live: issuedById was originally wired to
  // Employee, which meant every real issuance failed a foreign-key check
  // since no logged-in admin/manager/cashier's User.id ever coincidentally
  // matches an Employee.id. Matches the precedent already set by
  // Invoice.createdBy/Expense.createdBy/Payment.recordedBy, all of which
  // relate to User for exactly this reason.
  issuedBy User?            @relation("BloodIssueIssuedBy", fields: [issuedById], references: [id], onDelete: SetNull)
  items    BloodIssueItem[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model BloodIssueItem {
  id                String   @id @default(cuid())
  bloodIssueId      String
  donationRecordId  String   @unique
  bloodGroup        String
  componentType     String
  price             Float    @default(0)
  compatibilityNote String? // e.g. "O- recipient, issued A+ unit — INCOMPATIBLE, issued on override"
  // Phase 58 §2 — the documented reason for the emergency-release override,
  // required by createBloodIssue whenever an actually-incompatible unit is
  // issued anyway (default behavior is now to BLOCK, not just warn).
  overrideReason    String?
  createdAt         DateTime @default(now())

  bloodIssue     BloodIssue     @relation(fields: [bloodIssueId], references: [id], onDelete: Cascade)
  donationRecord DonationRecord @relation(fields: [donationRecordId], references: [id])

  @@index([bloodIssueId])
}

model ProviderSchedule {
  id           String   @id @default(cuid())
  providerId   String
  dayOfWeek    Int // 0=Sun, 1=Mon … 6=Sat
  isWorking    Boolean  @default(true)
  startTime    String // "09:00"
  endTime      String // "18:00"
  breakStart   String?
  breakEnd     String?
  slotDuration Int      @default(30)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  provider Employee @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, dayOfWeek])
  @@index([providerId])
}

model ClinicHoliday {
  id         String   @id @default(cuid())
  date       DateTime
  name       String
  isGlobal   Boolean  @default(true)
  providerId String?
  createdAt  DateTime @default(now())

  @@index([date])
  @@index([providerId])
}

model CancellationPolicy {
  id                   String   @id @default(cuid())
  noticePeriodHours    Int      @default(24)
  cancellationFeeType  String   @default("NONE") // NONE | FIXED | PERCENT
  cancellationFeeValue Float    @default(0)
  notes                String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model NotificationQueue {
  id               String    @id @default(cuid())
  appointmentId    String?
  customerId       String?
  customerName     String?
  customerPhone    String?
  notificationType String // APPOINTMENT_REMINDER|APPOINTMENT_CONFIRM|APPOINTMENT_CANCEL|CUSTOM
  templateBody     String
  whatsappLink     String?
  scheduledFor     DateTime?
  status           String    @default("PENDING") // PENDING | SENT | DISMISSED | FAILED
  sentAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([appointmentId])
  @@index([customerId])
  @@index([scheduledFor])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 23 — VETERINARY: PET MANAGEMENT
// ─────────────────────────────────────────────────────────────────────────────
model Pet {
  id          String    @id @default(cuid())
  customerId  String?
  petName     String
  species     String    @default("Dog") // Dog | Cat | Bird | Rabbit | Reptile | Other
  breed       String?
  dateOfBirth DateTime?
  gender      String? // Male | Female | Unknown
  color       String?
  weight      Float? // current weight in kg
  microchipId String?
  isActive    Boolean   @default(true)
  notes       String?
  photoPath   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer      Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  weightHistory WeightHistory[]
  vaccinations  VaccinationRecord[]
  appointments  Appointment[]

  @@index([customerId])
  @@index([species])
  @@index([isActive])
}

model WeightHistory {
  id         String   @id @default(cuid())
  petId      String
  weightKg   Float
  recordedAt DateTime @default(now())
  notes      String?

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([recordedAt])
}

model VaccinationRecord {
  id                 String    @id @default(cuid())
  petId              String
  vaccineName        String
  vaccineType        String? // Core | Non-core | Optional
  batchNumber        String?
  manufacturer       String?
  administeredAt     DateTime
  administeredBy     String?
  nextDueDate        DateTime?
  notes              String?
  certificatePrinted Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([nextDueDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// PHASE 24 — MEDICAL: VISIT NOTES (SOAP) + GP TOKEN QUEUE
// ─────────────────────────────────────────────────────────────────────────────

model VisitNote {
  id              String    @id @default(cuid())
  appointmentId   String    @unique
  patientName     String
  patientAge      String? // "35 years" or "6 months"
  chiefComplaint  String?
  subjective      String? // patient-reported history
  objective       String? // vitals and examination findings
  assessment      String? // diagnosis / differential
  plan            String? // treatment plan, medications, procedures
  followUpDate    DateTime?
  followUpNotes   String?
  referredBy      String? // specialist: who referred this patient
  referralDate    DateTime?
  referralReason  String?
  treatmentDone   String? // Phase 25 — Dental: what was done this session
  painScore       Int? // Phase 26 — Physio: pain score 0–10
  functionalScore Int? // Phase 58 §2 — Physio: structured functional outcome measure, 0-100 (higher = better function), trended across sessions alongside pain score
  treatmentGiven  String? // Phase 26 — Physio: modalities applied this session
  bpSystolic      Int? // Phase 54B — structured vitals, mmHg
  bpDiastolic     Int? // Phase 54B — structured vitals, mmHg
  pulseRate       Int? // Phase 54B — bpm
  temperatureF    Float? // Phase 54B — °F
  heightCm        Float? // Phase 54B
  weightKg        Float? // Phase 54B
  vitalsFlags     String? // Phase 54B — JSON: computed LOW|NORMAL|HIGH per vital, from NormalRangeReference
  isFinalized     Boolean   @default(false)
  finalizedAt     DateTime?
  createdBy       String // userId who created the note
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  appointment          Appointment        @relation("AppointmentOwnVisitNote", fields: [appointmentId], references: [id], onDelete: Cascade)
  referralAppointments Appointment[]      @relation("ReferralSource") // Phase 54F — real in-app referrals booked FROM this note (see Appointment.referredFromVisitNoteId)
  prescriptionItems    PrescriptionItem[] // Phase 58 §2 — GP/Specialist Clinic: structured drug/dosage/frequency/duration rows, replacing the single free-text `plan` field for anything meant to print as an actual prescription.

  @@index([createdBy])
  @@index([isFinalized])
  @@index([createdAt])
}

// Phase 58 §2 — GP/Specialist Clinic: a real structured prescription, distinct
// from the free-text `VisitNote.plan` field (which stays as a general
// treatment-plan note). One row per drug so a printable prescription can list
// dosage/frequency/duration per item instead of one paragraph a pharmacist
// has to parse by hand.
model PrescriptionItem {
  id           String   @id @default(cuid())
  visitNoteId  String
  drugName     String
  dosage       String? // e.g. "500mg"
  frequency    String? // e.g. "1-0-1" or "Twice daily"
  duration     String? // e.g. "5 days"
  instructions String? // e.g. "After food"
  sequence     Int      @default(0)
  createdAt    DateTime @default(now())

  visitNote VisitNote @relation(fields: [visitNoteId], references: [id], onDelete: Cascade)

  @@index([visitNoteId])
}

// Phase 54B — a single reusable "what's normal for this test" library shared
// by BOTH structured vitals (VisitNote.bpSystolic etc.) and lab test result
// parameters (LabTestOrderItem.resultParameters' referenceRange/flag) — one
// place to define/save a normal range instead of every lab tech retyping it
// per result and every doctor eyeballing vitals with no saved reference.
model NormalRangeReference {
  id           String   @id @default(cuid())
  testName     String // e.g. "Blood Pressure - Systolic", "Fasting Blood Sugar"
  unit         String? // e.g. "mmHg", "mg/dL"
  minValue     Float?
  maxValue     Float?
  // Phase 58 §2 — Diagnostic Lab: panic/critical-value thresholds, DISTINCT
  // from minValue/maxValue — a real clinical lab's "critical" tier sits
  // outside the normal range, not at its edge (e.g. FBS <40 or >400 mg/dL is
  // a life-threatening panic value, well past the merely-abnormal 70-100
  // normal band). Optional — most tests never need one; evaluateAgainstNormalRange
  // checks these FIRST, before falling back to the ordinary LOW/HIGH bounds.
  criticalLow  Float?
  criticalHigh Float?
  gender       String   @default("ALL") // ALL | MALE | FEMALE
  // Phase 58 §2 — Vet Clinic: a species dimension alongside gender, same
  // "ALL sentinel, not nullable" convention (a nullable column lets SQLite's
  // unique index treat every NULL as distinct, silently allowing duplicate
  // "generic" rows — the exact trap gender's own ALL default already avoids).
  // "ALL" here means human/species-agnostic; a vet's dog/cat-specific rows
  // (e.g. a dog's real body temperature range is nothing like a human's)
  // take priority when present, falling back to ALL exactly like gender does.
  species      String   @default("ALL")
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([testName, gender, species])
  @@index([testName])
}

model TokenQueue {
  id            String    @id @default(cuid())
