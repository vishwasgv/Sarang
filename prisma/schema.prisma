  status                  String    @default("ACTIVE") // ACTIVE|MAINTENANCE|RETIRED
  // Phase 58 §2 — Driving School: maintenance scheduling tied to actual
  // vehicle usage. odometerKm is staff-entered (there's no telematics feed),
  // updated whenever a service is logged; sessionsSinceService increments
  // automatically every time a DrivingSession for this vehicle is marked
  // COMPLETED and resets to 0 on the next service log — so "due for
  // service" can be computed from real usage instead of a fixed calendar
  // reminder no one maintains.
  odometerKm              Int       @default(0)
  serviceIntervalKm       Int       @default(5000)
  serviceIntervalSessions Int       @default(30)
  lastServiceOdometerKm   Int       @default(0)
  lastServiceDate         DateTime?
