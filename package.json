{
  "name": "sarang-business-os",
  "version": "1.0.0",
  "description": "Sarang Business OS Lite - Powered by Aszurex",
  "main": "out/main/index.js",
  "author": "Aszurex",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node src/main/database/seed.ts",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node tests/e2e/run-all.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@prisma/client": "^6.2.1",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/react-virtual": "^3.14.3",
    "@types/archiver": "^8.0.0",
    "archiver": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "framer-motion": "^11.15.0",
    "i18next": "^26.3.1",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.469.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.28.1",
    "recharts": "^2.15.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@fontsource/noto-sans-devanagari": "^5.2.8",
    "@fontsource/noto-sans-gujarati": "^5.2.7",
    "@fontsource/noto-sans-kannada": "^5.2.9",
    "@fontsource/noto-sans-malayalam": "^5.2.8",
    "@fontsource/noto-sans-tamil": "^5.2.7",
    "@fontsource/noto-sans-telugu": "^5.2.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "playwright-core": "^1.61.1",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.9"
  }
}
